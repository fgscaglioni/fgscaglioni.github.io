---
import { my_stack } from "../data/siteData";
---

<div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 lg:grid-cols-8 gap-3">
  {my_stack.map((item) => {
    const Tag = item.url ? "a" : "div";
    const props = item.url
      ? { href: item.url, target: "_blank", rel: "noopener noreferrer" }
      : {};

    return (
      <Tag
        {...props}
        class="group stack-link flex flex-col items-center gap-2.5 p-3 transition-all duration-200"
      >
        <div class="w-10 h-10 flex items-center justify-center border border-gray-200 bg-white group-hover:bg-gray-100 group-hover:border-gray-300 transition-colors overflow-hidden p-1.5 opacity-60 group-hover:opacity-100">
          <img
            src={item.image}
            alt={`${item.name} logo`}
            class="max-h-full max-w-full object-contain"
            loading="lazy"
          />
        </div>
        <span class="text-[10px] text-center text-gray-400 font-bold tracking-wider uppercase group-hover:text-gray-700 transition-colors leading-tight">
          {item.name}
        </span>
      </Tag>
    );
  })}
</div>
