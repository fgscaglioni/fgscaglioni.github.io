---
import { my_stack } from '../data/siteData';

// We map through the object property keys to display them nicely
const stackEntries = Object.entries(my_stack).map(([key, category]) => category);
---

<div class="space-y-12">
  {stackEntries.map((category) => (
    <div class="group">
      <h3 class="text-xl font-bold mb-4 pb-2 border-b-2 inline-block transition-colors" style={`border-color: ${category.color}`}>
        {category.title}
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
        {category.data.map((item) => {
          const Tag = item.url ? 'a' : 'div';
          const props = item.url ? { href: item.url, target: '_blank', rel: 'noopener noreferrer' } : {};
          
          return (
            <Tag
              {...props}
              class="flex flex-col items-center p-4 bg-gray-50 rounded-lg shadow-sm hover:shadow-md transition-all sm:p-6"
            >
              <div class="h-16 w-16 mb-4 flex items-center justify-center p-2 rounded-full bg-white object-contain shadow-sm border border-gray-100 overflow-hidden">
                <img 
                  src={item.image} 
                  alt={`${item.name} logo`} 
                  class="max-h-full max-w-full object-contain" 
                  loading="lazy"
                />
              </div>
              <span class="text-sm font-medium text-center text-gray-700">{item.name}</span>
            </Tag>
          )
        })}
      </div>
    </div>
  ))}
</div>
