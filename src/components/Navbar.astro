---
import { siteLinks } from "../data/siteData";
import PaperCard from "../components/PaperCard.astro";
const currentPath = Astro.url.pathname;
---

<header class="sticky top-4 z-50 px-4 max-w-3xl mx-auto w-full">
  <PaperCard class=" px-4 py-3 flex items-center justify-between bg-white/80 backdrop-blur-md border border-gray-200 rounded-full">
    <!-- Brand Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-full border border-gray-200 bg-gray-100 flex items-center justify-center transition-all duration-300 group-hover:bg-teal-600 group-hover:border-teal-600">
        <span class="font-display italic text-base font-bold text-gray-700 group-hover:text-white">fg</span>
      </div>
      <span class="font-display italic text-lg text-gray-800 group-hover:text-gray-500 transition-colors hidden xs:inline">
        fgscaglioni
      </span>
    </a>

    <!-- Top Navigation Links -->
    <nav class="flex items-center gap-1 sm:gap-2">
      {
        siteLinks.main.slice(0, 6).map((link) => {
          const isActive = currentPath === link.href || currentPath === link.href + "/";
          return (
            <a
              href={link.href}
              class={`px-3 py-1.5 rounded-full text-xs font-medium tracking-wide transition-all duration-300 ${
                isActive
                  ? "bg-teal-600 text-white shadow-sm"
                  : "text-gray-500 hover:text-gray-800 hover:bg-gray-100"
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </PaperCard>
</header>

<style>
  @media (max-width: 380px) {
    /* Hide some items on ultra-small screens to prevent overflow */
    nav a:nth-child(4),
    nav a:nth-child(5) {
      display: none;
    }
  }
</style>
