---
import PaperCard from "./PaperCard.astro";

interface Props {
  icon: string;
  title: string;
  subtitle: string;
  class?: string;
}

const { icon, title, subtitle, class: className = "" } = Astro.props;
---

<PaperCard class="p-6 sm:p-8 mb-8 relative overflow-hidden {className}">
  <div class="flex items-center gap-4 relative">
    <div class="w-12 h-12 rounded-lg border border-gray-200 bg-gray-100 flex items-center justify-center flex-shrink-0">
      <i class={`fa-solid fa-${icon} text-gray-500 text-xl`}></i>
    </div>
    <div>
      <h1 class="text-3xl sm:text-4xl font-display italic tracking-wide text-gray-900">{title}</h1>
      <p class="text-gray-500 text-xs mt-1 uppercase tracking-widest font-bold">{subtitle}</p>
    </div>
  </div>
</PaperCard>
