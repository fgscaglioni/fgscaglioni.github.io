---
// src/components/Header.astro
import { siteLinks } from "../data/siteData";
const currentPath = Astro.url.pathname;
---

<header class="flex justify-between items-center pb-4 border-b mb-8 relative">
  <div>
    <a href="/" class="text-xl font-bold hover:text-blue-600 transition-colors"
      >@fgscaglioni</a
    >
  </div>

  <nav class="flex items-center">
    <!-- Mobile Hamburger Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center p-2 rounded-md text-gray-700 hover:text-blue-600 hover:bg-gray-100 transition-colors focus:outline-none"
    >
      <i class="fa-solid fa-bars text-xl"></i>
    </button>

    <!-- Desktop Dropdown (Original format, visible only on medium screens and up) -->
    <div class="hidden md:flex items-center relative group">
      <div
        class="cursor-pointer flex items-center gap-2 hover:text-blue-600 font-medium"
      >
        <i class="fa-solid fa-ellipsis-vertical text-gray-400"></i> Links
      </div>

      <!-- Dropdown menu -->
      <div
        class="absolute right-0 top-full mt-2 w-48 bg-white border border-gray-100 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 overflow-hidden"
      >
        {
          siteLinks.external.map((link, idx) => (
            <a
              href={link.href}
              target={link.newTab ? "_blank" : "_self"}
              rel={link.newTab ? "noopener noreferrer" : ""}
              class={`px-4 py-3 hover:bg-blue-50 transition-colors flex items-center gap-3 text-sm font-medium text-gray-700 ${
                idx > 0 ? "border-t border-gray-50" : ""
              }`}
            >
              <i
                class={`${
                  link.icon.startsWith("fa-") && link.icon !== "fa-download"
                    ? "fa-brands"
                    : "fa-solid"
                } ${link.icon} text-gray-400 w-4 text-center`}
              />{" "}
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Mobile Dropdown Menu -->
    <div
      id="mobile-menu"
      class="hidden absolute top-[calc(100%+0.5rem)] right-0 w-64 bg-white border border-gray-100 rounded-xl shadow-2xl z-50 overflow-hidden md:hidden"
    >
      <div class="py-2 bg-gray-50/80 border-b border-gray-100">
        <span
          class="px-4 text-xs font-bold text-gray-500 uppercase tracking-wider block"
          >Navegar</span
        >
      </div>
      <div class="flex flex-col">
        {
          siteLinks.main.map((link) => {
            const isActive =
              currentPath === link.href || currentPath === link.href + "/";
            return (
              <a
                href={link.href}
                class={`px-4 py-3.5 flex flex-col justify-center border-b border-gray-50 transition-colors
                ${
                  isActive
                    ? "bg-blue-50 text-blue-700 font-semibold"
                    : "text-gray-700 hover:bg-gray-50"
                }`}
              >
                {link.label}
              </a>
            );
          })
        }
      </div>

      <div class="py-2 bg-gray-50/80 border-b border-gray-100">
        <span
          class="px-4 text-xs font-bold text-gray-500 uppercase tracking-wider block"
          >Externos</span
        >
      </div>
      <div class="flex flex-col">
        {
          siteLinks.external.map((link) => (
            <a
              href={link.href}
              target={link.newTab ? "_blank" : "_self"}
              rel={link.newTab ? "noopener noreferrer" : ""}
              class="px-4 py-3.5 hover:bg-blue-50 text-gray-700 border-b border-gray-50 transition-colors flex items-center gap-3"
            >
              <div class="w-5 text-center">
                <i
                  class={`${
                    link.icon.startsWith("fa-") && link.icon !== "fa-download"
                      ? "fa-brands"
                      : "fa-solid"
                  } ${link.icon} text-gray-400`}
                />
              </div>
              <span class="font-medium">{link.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<script>
  // Script minimalista para garantir o acionamento do menu mobile localmente e entre as páginas (usando document event listener puro para contornar qualquer caching)
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (btn && menu) {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        menu.classList.toggle("hidden");
      });

      document.addEventListener("click", (event) => {
        const target = event.target as Node;
        if (!btn.contains(target) && !menu.contains(target)) {
          menu.classList.add("hidden");
        }
      });
    }
  });
</script>
