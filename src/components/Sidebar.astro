---
import "@fortawesome/fontawesome-free/css/all.min.css";
import { siteLinks } from "../data/siteData";

const currentPath = Astro.url.pathname;
---

<div class="h-full py-8 pr-8 border-r">
  <h2 class="text-2xl font-bold mb-6 tracking-tight">Menu</h2>

  <nav class="flex flex-col space-y-3">
    {
      siteLinks.main.map((link) => (
        <a
          href={link.href}
          class={`text-lg transition-colors hover:text-blue-600 flex items-center gap-2 ${
            currentPath === link.href || currentPath === link.href + "/"
              ? "font-bold text-blue-600"
              : "text-gray-700"
          }`}
        >
          <i class={`fa-solid ${link.icon} w-5 text-center`} /> {link.label}
        </a>
      ))
    }
  </nav>
</div>
