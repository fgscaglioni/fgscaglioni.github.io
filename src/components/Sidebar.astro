---
import { siteLinks } from "../data/siteData";
const currentPath = Astro.url.pathname;
---

<aside class="flex flex-col h-full py-8 px-6">
  <!-- Logo / Brand -->
  <div class="mb-10">
    <a href="/" class="group flex items-center gap-3">
      <div
        class="w-10 h-10 border-2 border-slate-200 bg-[#0a0a0a] flex items-center justify-center transition-all duration-300 group-hover:bg-slate-200 group-hover:text-[#0a0a0a]"
      >
        <span class="font-display italic text-xl">fg</span>
      </div>
      <div>
        <div
          class="font-display italic text-xl leading-tight text-white group-hover:text-slate-300 transition-colors"
        >
          fgscaglioni
        </div>
        <!-- <div class="text-slate-500 text-xs tracking-wider uppercase">
          Portfólio
        </div> -->
      </div>
    </a>
  </div>

  <!-- Navigation -->
  <nav class="flex-grow space-y-1">
    <p
      class="text-xs font-semibold text-slate-600 uppercase tracking-wider mb-3"
    >
      Navegação
    </p>
    {
      siteLinks.main.map((link) => {
        const isActive =
          currentPath === link.href || currentPath === link.href + "/";
        return (
          <a
            href={link.href}
            class={`flex items-center gap-3 px-3 py-2.5 text-sm font-medium transition-all duration-200 group border-l-2
            ${
              isActive
                ? "border-l-slate-200 bg-white/5 text-white"
                : "border-l-transparent text-slate-400 hover:text-white hover:bg-white/5"
            }`}
          >
            <div
              class={`w-8 h-8 flex items-center justify-center transition-all duration-200`}
            >
              <i
                class={`fa-solid ${link.icon} text-sm ${
                  isActive
                    ? "text-white"
                    : "text-slate-500 group-hover:text-white"
                }`}
              />
            </div>
            {link.label}
          </a>
        );
      })
    }

    <div class="pt-4 pb-2">
      <p
        class="text-xs font-semibold text-slate-600 uppercase tracking-wider mb-3"
      >
        Links Externos
      </p>
    </div>
    {
      siteLinks.external.map((link) => (
        <a
          href={link.href}
          target={link.newTab ? "_blank" : "_self"}
          rel={link.newTab ? "noopener noreferrer" : ""}
          class="flex items-center gap-3 px-3 py-2.5 rounded-sm text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 border border-transparent transition-all duration-200 group"
        >
          <div class="w-8 h-8 flex items-center justify-center transition-all duration-200">
            <i
              class={`${link.icon === "fa-medium" ? "fa-brands" : "fa-solid"} ${
                link.icon
              } text-sm text-slate-500 group-hover:text-white`}
            />
          </div>
          {link.label}
          {link.newTab && (
            <i class="fa-solid fa-arrow-up-right-from-square text-[10px] ml-auto opacity-40 group-hover:text-slate-300" />
          )}
        </a>
      ))
    }
  </nav>

  <!-- Footer Decoration -->
  <div class="mt-auto pt-6 border-t border-white/5">
    <p class="text-xs text-slate-600 text-center">
      © {new Date().getFullYear()} Fabrício Scaglioni
    </p>
  </div>
</aside>
