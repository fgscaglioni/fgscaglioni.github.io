---
import '@fortawesome/fontawesome-free/css/all.min.css';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: '🏠 Home' },
  { href: '/experience', label: '🗂️ Jobs' },
  { href: '/social', label: '💬 Social' }
];
---

<div class="h-full py-8 pr-8 border-r">
  <h2 class="text-2xl font-bold mb-6 tracking-tight">Menu</h2>
  
  <nav class="flex flex-col space-y-3">
    {links.map(link => (
      <a 
        href={link.href} 
        class={`text-lg transition-colors hover:text-blue-600 ${currentPath === link.href || currentPath === link.href + '/' ? 'font-bold text-blue-600' : 'text-gray-700'}`}
      >
        {link.label}
      </a>
    ))}
  </nav>
</div>
