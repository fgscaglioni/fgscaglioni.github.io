---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Blog Fabrício Scaglioni`}>
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <div class="mb-8 border-b border-gray-100 pb-6">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-gray-400 hover:text-gray-700 transition-colors mb-6"
      >
        <i class="fa-solid fa-arrow-left text-[10px]" /> Voltar ao Journal
      </a>
      <span class="font-mono text-[9px] text-gray-400 uppercase tracking-widest block mb-2">
        {
          post.data.pubDate.toLocaleDateString("pt-BR", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </span>
      <h1 class="text-3xl sm:text-4xl font-display italic text-gray-900 leading-tight mb-4">
        {post.data.title}
      </h1>
      <p class="text-gray-500 text-sm italic font-light">
        {post.data.description}
      </p>
    </div>

    <!-- Article Content -->
    <div class="prose max-w-none text-gray-700 text-sm leading-relaxed space-y-5
      prose-headings:font-display prose-headings:italic prose-headings:text-gray-900
      prose-h2:text-xl prose-h2:border-b prose-h2:border-gray-100 prose-h2:pb-2 prose-h2:mt-8
      prose-p:leading-relaxed
      prose-a:text-teal-600 prose-a:underline prose-a:underline-offset-2 prose-a:hover:text-teal-800
      prose-code:text-rose-600 prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:text-xs prose-code:rounded-md
      prose-pre:bg-gray-50 prose-pre:border prose-pre:border-gray-200 prose-pre:p-4 prose-pre:rounded-xl prose-pre:font-mono
      prose-strong:text-gray-900 prose-strong:font-medium
      prose-ul:list-square prose-ul:pl-5 prose-ul:space-y-2
      prose-li:text-gray-700">
      <Content />
    </div>
  </article>
</BaseLayout>
