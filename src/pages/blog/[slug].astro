---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import PaperCard from "../../components/PaperCard.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Find related posts by tag overlap
const allPosts = (await getCollection("blog"))
  .filter((p) => p.id !== post.id && !p.data.draft);

const postTags = post.data.tags || [];

const related = allPosts
  .map((p) => ({
    post: p,
    score: (p.data.tags || []).filter((t) => postTags.includes(t)).length,
  }))
  .filter((p) => p.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);
---

<BaseLayout title={`${post.data.title} | Blog Fabrício Scaglioni`}>
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <div class="mb-8 border-b border-gray-100 pb-6">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-gray-400 hover:text-gray-700 transition-colors mb-6"
      >
        <i class="fa-solid fa-arrow-left text-[10px]" /> Voltar ao Journal
      </a>
      <span class="font-mono text-[9px] text-gray-400 uppercase tracking-widest block mb-2">
        {
          post.data.pubDate.toLocaleDateString("pt-BR", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </span>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 mb-4">
          {post.data.tags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="font-mono text-[9px] px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 hover:bg-teal-100 hover:text-teal-700 uppercase tracking-wider transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
      <h1 class="text-3xl sm:text-4xl font-display italic text-gray-900 leading-tight mb-4">
        {post.data.title}
      </h1>
      <p class="text-gray-500 text-sm italic font-light">
        {post.data.description}
      </p>
    </div>

    <!-- Article Content -->
    <div class="prose max-w-none text-gray-700 text-sm leading-relaxed space-y-5
      prose-headings:font-display prose-headings:italic prose-headings:text-gray-900
      prose-h2:text-xl prose-h2:border-b prose-h2:border-gray-100 prose-h2:pb-2 prose-h2:mt-8
      prose-p:leading-relaxed
      prose-a:text-teal-600 prose-a:underline prose-a:underline-offset-2 prose-a:hover:text-teal-800
      prose-code:not(pre code):text-rose-600 prose-code:not(pre code):bg-rose-50 prose-code:not(pre code):px-1.5 prose-code:not(pre code):py-0.5 prose-code:not(pre code):font-mono prose-code:not(pre code):text-xs prose-code:not(pre code):rounded-md
      prose-pre:bg-[#F6F8FA] prose-pre:border prose-pre:border-gray-200 prose-pre:p-4 prose-pre:rounded-xl prose-pre:font-mono prose-pre:text-sm
      prose-strong:text-gray-900 prose-strong:font-medium
      prose-ul:list-square prose-ul:pl-5 prose-ul:space-y-2
      prose-li:text-gray-700">
      <Content />
    </div>

    <!-- Related Posts -->
    {related.length > 0 && (
      <div class="mt-12 pt-8 border-t border-gray-100">
        <h2 class="text-xl font-display italic text-gray-900 mb-6">Posts Relacionados</h2>
        <div class="space-y-4">
          {related.map(({ post: p }) => (
            <a href={`/blog/${p.id}`} class="block group">
              <PaperCard class="p-5 transition-shadow duration-200 group-hover:shadow-md">
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-mono text-[9px] text-gray-400 uppercase tracking-widest">
                    {p.data.pubDate.toLocaleDateString("pt-BR", { year: "numeric", month: "short" })}
                  </span>
                  {p.data.tags && p.data.tags.length > 0 && (
                    <>
                      <span class="text-gray-300">·</span>
                      {p.data.tags.slice(0, 2).map((t) => (
                        <span class="font-mono text-[9px] px-2 py-0.5 rounded-full bg-gray-100 text-gray-500 uppercase tracking-wider">
                          {t}
                        </span>
                      ))}
                    </>
                  )}
                </div>
                <h3 class="text-base font-display italic text-gray-900 group-hover:text-teal-600 transition-colors">
                  {p.data.title}
                </h3>
              </PaperCard>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
