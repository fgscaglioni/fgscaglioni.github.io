---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import { getCollection } from "astro:content";
import PaperCard from "../../components/PaperCard.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Research Journal & Blog | Fabrício Scaglioni">
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <PaperCard class=" p-6 sm:p-8 mb-6 relative overflow-hidden">
      <div class="flex items-center gap-4 relative">
        <div class="w-12 h-12 rounded-lg border border-gray-200 bg-gray-100 flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-feather text-gray-500 text-xl"></i>
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-display italic tracking-wide text-gray-900">
            Journal de Pesquisa
          </h1>
          <p class="text-gray-400 text-xs mt-1 uppercase tracking-widest font-bold">
            Reflexões sobre Inteligência Artificial, Engenharia e Doutorado
          </p>
        </div>
      </div>
    </PaperCard>

    <!-- Posts List -->
    <div class="space-y-6">
      {
        posts.map((post) => (
          <PaperCard class=" p-6">
            <span class="font-mono text-[9px] text-gray-400 uppercase tracking-widest block mb-2">
              {post.data.pubDate.toLocaleDateString("pt-BR", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
            <h2 class="text-xl sm:text-2xl font-display italic text-gray-900 mb-3">
              <a
                href={`/blog/${post.id}`}
                class="hover:text-gray-700 transition-colors"
              >
                {post.data.title}
              </a>
            </h2>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">
              {post.data.description}
            </p>
            <a
              href={`/blog/${post.id}`}
              class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-gray-700 hover:text-gray-900 transition-colors"
            >
              Ler Artigo <i class="fa-solid fa-arrow-right text-[10px]" />
            </a>
          </PaperCard>
        ))
      }
    </div>
  </article>
</BaseLayout>
