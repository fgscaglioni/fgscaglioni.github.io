---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Research Journal & Blog | Fabrício Scaglioni">
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <div class="brutalist-card p-8 mb-10 sharp-hover relative overflow-hidden">
      <div class="flex items-center gap-4 relative">
        <div
          class="w-12 h-12 border border-slate-700 bg-[#0a0a0a] flex items-center justify-center flex-shrink-0"
        >
          <i class="fa-solid fa-feather text-slate-400 text-xl"></i>
        </div>
        <div>
          <h1 class="text-4xl font-display italic tracking-wide text-white">
            Journal de Pesquisa & Blog
          </h1>
          <p
            class="text-slate-500 text-sm mt-1 uppercase tracking-widest font-bold"
          >
            Reflexões sobre Inteligência Artificial, Engenharia e Doutorado
          </p>
        </div>
      </div>
    </div>

    <!-- Posts List -->
    <div class="space-y-6">
      {
        posts.map((post) => (
          <div class="brutalist-card p-6 sharp-hover">
            <span class="font-mono text-[10px] text-slate-500 uppercase tracking-widest">
              {post.data.pubDate.toLocaleDateString("pt-BR", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
            <h2 class="text-2xl font-display italic text-white mt-2 mb-3">
              <a
                href={`/blog/${post.id}`}
                class="hover:text-slate-300 transition-colors"
              >
                {post.data.title}
              </a>
            </h2>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">
              {post.data.description}
            </p>
            <a
              href={`/blog/${post.id}`}
              class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-slate-300 hover:text-white transition-colors"
            >
              Ler Artigo <i class="fa-solid fa-arrow-right text-[10px]" />
            </a>
          </div>
        ))
      }
    </div>
  </article>
</BaseLayout>
