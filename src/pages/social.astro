---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

const socialLinks = [
  {
    name: "GitHub",
    url: "http://github.com/fgscaglioni/",
    icon: "fa-github",
    brand: true,
    color: "bg-[#050505] border-slate-700 hover:border-slate-500",
    iconColor: "text-slate-300",
  },
  {
    name: "Medium",
    url: "https://medium.com/@fgscaglioni",
    icon: "fa-medium",
    brand: true,
    color: "bg-[#050505] border-slate-700 hover:border-slate-500",
    iconColor: "text-slate-300",
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/fgscaglioni/",
    icon: "fa-linkedin",
    brand: true,
    color: "bg-[#050505] border-slate-700 hover:border-slate-500",
    iconColor: "text-slate-300",
  },
  {
    name: "X (Twitter)",
    url: "https://x.com/fgscaglioni",
    icon: "fa-x-twitter",
    brand: true,
    color: "bg-[#050505] border-slate-700 hover:border-slate-500",
    iconColor: "text-slate-300",
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/fgscaglioni",
    icon: "fa-instagram",
    brand: true,
    color: "bg-[#050505] border-slate-700 hover:border-slate-500",
    iconColor: "text-slate-300",
  },
];

const academicLinks = [
  {
    name: "Google Scholar",
    url: "https://scholar.google.com/citations?user=fZEKGvUAAAAJ",
    icon: "fa-google",
    brand: true,
    desc: "Publicações e citações acadêmicas",
    color: "text-slate-400",
  },
  {
    name: "Lattes",
    url: "https://lattes.cnpq.br/0870115674210417",
    icon: "fa-id-card",
    brand: false,
    desc: "Currículo Lattes CNPq",
    color: "text-slate-400",
  },
  {
    name: "Orcid",
    url: "https://orcid.org/0000-0002-9749-2077",
    icon: "fa-id-badge",
    brand: false,
    desc: "Identificador de pesquisador",
    color: "text-slate-400",
  },
  {
    name: "Kaggle",
    url: "https://www.kaggle.com/fgscaglioni",
    icon: "fa-k",
    brand: false,
    desc: "Competições e notebooks de ML",
    color: "text-slate-400",
  },
  {
    name: "ResearchGate",
    url: "https://www.researchgate.net/profile/Fabricio-Scaglioni",
    icon: "fa-r",
    brand: false,
    desc: "Rede de colaboração científica",
    color: "text-slate-400",
  },
  {
    name: "Parsifal",
    url: "https://parsif.al/fgscaglioni/",
    icon: "fa-magnifying-glass-chart",
    brand: false,
    desc: "Revisões sistemáticas da literatura",
    color: "text-slate-400",
  },
  {
    name: "Semantic Scholar",
    url: "https://www.semanticscholar.org/author/2202206947",
    icon: "fa-graduation-cap",
    brand: false,
    desc: "Pesquisa acadêmica com IA",
    color: "text-slate-400",
  },
  {
    name: "ResearchId",
    url: "https://researchid.co/fgscaglioni",
    icon: "fa-fingerprint",
    brand: false,
    desc: "Perfil unificado de pesquisador",
    color: "text-slate-400",
  },
];
---

<BaseLayout title="Social e Científico | @fgscaglioni">
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article class="pt-8 pb-16">
    <article class="pt-8 pb-16">
      <!-- Page Header -->
      <div
        class="brutalist-card p-8 mb-12 sharp-hover relative overflow-hidden"
      >
        <div class="flex items-center gap-4 relative">
          <div
            class="w-12 h-12 border border-slate-700 bg-[#0a0a0a] flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-solid fa-users text-slate-400 text-xl"></i>
          </div>
          <div>
            <h1 class="text-4xl font-display italic tracking-wide text-white">
              Redes Sociais e Científicas
            </h1>
            <p
              class="text-slate-500 text-sm mt-1 uppercase tracking-widest font-bold"
            >
              Perfis profissionais, pessoais e acadêmicos
            </p>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Social Networks -->
        <section>
          <div
            class="flex items-center gap-3 mb-6 border-b border-slate-800 pb-3"
          >
            <div
              class="w-8 h-8 flex items-center justify-center border border-slate-700"
            >
              <i class="fa-solid fa-share-nodes text-slate-400 text-xs"></i>
            </div>
            <h2 class="text-2xl font-display italic text-white tracking-wide">
              Redes Sociais
            </h2>
          </div>
          <div class="space-y-4">
            {
              socialLinks.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`group flex items-center gap-4 p-4 ${link.color} border transition-all duration-300 hover:-translate-y-1 hover:shadow-[4px_4px_0px_#262626]`}
                >
                  <div class="w-10 h-10 border border-slate-700 bg-[#0a0a0a] group-hover:bg-slate-800 flex items-center justify-center flex-shrink-0 transition-colors">
                    <i
                      class={`${link.brand ? "fa-brands" : "fa-solid"} ${
                        link.icon
                      } ${
                        link.iconColor
                      } group-hover:text-white text-lg transition-colors`}
                    />
                  </div>
                  <span class="text-slate-300 font-bold uppercase tracking-wider group-hover:text-white transition-colors">
                    {link.name}
                  </span>
                  <i class="fa-solid fa-arrow-right text-xs text-slate-500 group-hover:text-slate-300 ml-auto transition-colors" />
                </a>
              ))
            }
          </div>
        </section>

        <!-- Academic Networks -->
        <section>
          <div
            class="flex items-center gap-3 mb-6 border-b border-slate-800 pb-3"
          >
            <div
              class="w-8 h-8 flex items-center justify-center border border-slate-700"
            >
              <i class="fa-solid fa-microscope text-slate-400 text-xs"></i>
            </div>
            <h2 class="text-2xl font-display italic text-white tracking-wide">
              Redes Acadêmicas
            </h2>
          </div>
          <div class="space-y-3">
            {
              academicLinks.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center gap-4 p-4 brutalist-card sharp-hover transition-all duration-200"
                >
                  <div class="w-8 h-8 border border-slate-700 bg-slate-900 group-hover:bg-slate-800 flex items-center justify-center flex-shrink-0 transition-colors">
                    <i
                      class={`${link.brand ? "fa-brands" : "fa-solid"} ${
                        link.icon
                      } ${
                        link.color
                      } group-hover:text-white transition-colors text-sm`}
                    />
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="text-slate-300 font-bold uppercase tracking-wider text-sm group-hover:text-white transition-colors">
                      {link.name}
                    </div>
                    <div class="text-slate-500 font-light text-xs truncate mt-1">
                      {link.desc}
                    </div>
                  </div>
                  <i class="fa-solid fa-arrow-right text-xs text-slate-600 group-hover:text-slate-300 transition-colors flex-shrink-0" />
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </article>
  </article>
</BaseLayout>
