---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

const socialLinks = [
  {
    name: "GitHub",
    url: "http://github.com/fgscaglioni/",
    icon: "fa-github",
    brand: true,
    color:
      "from-gray-600/20 to-gray-700/20 border-gray-600/30 hover:border-gray-500/40",
    iconColor: "text-gray-300",
  },
  {
    name: "Medium",
    url: "https://medium.com/@fgscaglioni",
    icon: "fa-medium",
    brand: true,
    color:
      "from-green-900/20 to-green-800/20 border-green-700/30 hover:border-green-600/40",
    iconColor: "text-green-400",
  },
  {
    name: "LinkedIn",
    url: "https://www.linkedin.com/in/fgscaglioni/",
    icon: "fa-linkedin",
    brand: true,
    color:
      "from-blue-900/20 to-blue-800/20 border-blue-700/30 hover:border-blue-600/40",
    iconColor: "text-blue-400",
  },
  {
    name: "X (Twitter)",
    url: "https://x.com/fgscaglioni",
    icon: "fa-x-twitter",
    brand: true,
    color:
      "from-slate-800/30 to-slate-700/20 border-slate-600/30 hover:border-slate-500/40",
    iconColor: "text-white",
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/fgscaglioni",
    icon: "fa-instagram",
    brand: true,
    color:
      "from-pink-900/20 to-purple-900/20 border-pink-700/30 hover:border-pink-600/40",
    iconColor: "text-pink-400",
  },
];

const academicLinks = [
  {
    name: "Google Scholar",
    url: "https://scholar.google.com/citations?user=fZEKGvUAAAAJ",
    icon: "fa-google",
    brand: true,
    desc: "Publicações e citações acadêmicas",
    color: "text-yellow-400",
  },
  {
    name: "Lattes",
    url: "https://lattes.cnpq.br/0870115674210417",
    icon: "fa-id-card",
    brand: false,
    desc: "Currículo Lattes CNPq",
    color: "text-green-400",
  },
  {
    name: "Orcid",
    url: "https://orcid.org/0000-0002-9749-2077",
    icon: "fa-id-badge",
    brand: false,
    desc: "Identificador de pesquisador",
    color: "text-lime-400",
  },
  {
    name: "Kaggle",
    url: "https://www.kaggle.com/fgscaglioni",
    icon: "fa-k",
    brand: false,
    desc: "Competições e notebooks de ML",
    color: "text-blue-400",
  },
  {
    name: "ResearchGate",
    url: "https://www.researchgate.net/profile/Fabricio-Scaglioni",
    icon: "fa-r",
    brand: false,
    desc: "Rede de colaboração científica",
    color: "text-teal-400",
  },
  {
    name: "Parsifal",
    url: "https://parsif.al/fgscaglioni/",
    icon: "fa-magnifying-glass-chart",
    brand: false,
    desc: "Revisões sistemáticas da literatura",
    color: "text-purple-400",
  },
  {
    name: "Semantic Scholar",
    url: "https://www.semanticscholar.org/author/2202206947",
    icon: "fa-graduation-cap",
    brand: false,
    desc: "Pesquisa acadêmica com IA",
    color: "text-indigo-400",
  },
  {
    name: "ResearchId",
    url: "https://researchid.co/fgscaglioni",
    icon: "fa-fingerprint",
    brand: false,
    desc: "Perfil unificado de pesquisador",
    color: "text-gray-400",
  },
];
---

<BaseLayout title="Social e Científico | @fgscaglioni">
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <div class="glass rounded-2xl p-8 mb-8 glow-hover relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-br from-purple-500/5 to-transparent pointer-events-none rounded-2xl"
      >
      </div>
      <div class="flex items-center gap-4 relative">
        <div
          class="w-12 h-12 rounded-2xl bg-purple-500/20 flex items-center justify-center flex-shrink-0 border border-purple-500/20"
        >
          <i class="fa-solid fa-users text-purple-400 text-xl"></i>
        </div>
        <div>
          <h1 class="text-3xl font-bold gradient-text">
            Redes Sociais e Científicas
          </h1>
          <p class="text-slate-500 text-sm mt-1">
            Perfis profissionais, pessoais e acadêmicos
          </p>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">
      <!-- Social Networks -->
      <section>
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-8 h-8 rounded-lg bg-blue-500/20 flex items-center justify-center"
          >
            <i class="fa-solid fa-share-nodes text-blue-400 text-sm"></i>
          </div>
          <h2 class="text-base font-bold text-white">Redes Sociais</h2>
        </div>
        <div class="space-y-3">
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class={`group flex items-center gap-4 p-4 rounded-2xl bg-gradient-to-r ${link.color} border backdrop-blur-sm transition-all duration-300 hover:scale-[1.02] hover:shadow-lg`}
              >
                <div class="w-10 h-10 rounded-xl bg-white/5 group-hover:bg-white/10 flex items-center justify-center flex-shrink-0 transition-colors">
                  <i
                    class={`${link.brand ? "fa-brands" : "fa-solid"} ${
                      link.icon
                    } ${link.iconColor} text-lg`}
                  />
                </div>
                <span class="text-slate-200 font-semibold group-hover:text-white transition-colors">
                  {link.name}
                </span>
                <i class="fa-solid fa-arrow-up-right-from-square text-xs text-slate-500 group-hover:text-slate-300 ml-auto transition-colors" />
              </a>
            ))
          }
        </div>
      </section>

      <!-- Academic Networks -->
      <section>
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-8 h-8 rounded-lg bg-teal-500/20 flex items-center justify-center"
          >
            <i class="fa-solid fa-microscope text-teal-400 text-sm"></i>
          </div>
          <h2 class="text-base font-bold text-white">Redes Acadêmicas</h2>
        </div>
        <div class="space-y-2">
          {
            academicLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-4 p-4 rounded-xl glass hover:border-white/20 transition-all duration-200"
              >
                <div class="w-8 h-8 rounded-lg bg-white/5 group-hover:bg-white/10 flex items-center justify-center flex-shrink-0 transition-colors">
                  <i
                    class={`${link.brand ? "fa-brands" : "fa-solid"} ${
                      link.icon
                    } ${link.color} text-sm`}
                  />
                </div>
                <div class="min-w-0 flex-1">
                  <div class="text-slate-200 font-medium text-sm group-hover:text-white transition-colors">
                    {link.name}
                  </div>
                  <div class="text-slate-600 text-xs truncate">{link.desc}</div>
                </div>
                <i class="fa-solid fa-chevron-right text-xs text-slate-700 group-hover:text-slate-400 transition-colors flex-shrink-0" />
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
