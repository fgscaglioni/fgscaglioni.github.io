---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';

// Data adapted from the markdown source
const experiences = [
  {
    role: "Analista de TI (Engenheiro de Software Sênior)",
    company: "Universidade Federal de Pelotas",
    tag: "Tempo Integral",
    url: "https://ufpel.edu.br/",
    period: "Nov/2008 – Atualmente",
    current: true,
    description: [
      "Atuo como Desenvolvedor Fullstack no projeto Cobalto, um ecossistema acadêmico complexo e modular. Migrei arquiteturas legadas, como o sistema GOL, integrando-as aos novos padrões da instituição.",
      "Idealizador e desenvolvedor principal do Aplicativo Universitário, centralizando notas, frequências e serviços para dezenas de milhares de estudantes.",
      "Integrei a equipe responsável por estruturar e desenvolver a transição de endpoints PHP legados para uma API moderna utilizando NestJS e Node.js em containers."
    ],
    skills: ["PHP", "Laravel", "NestJS", "CodeIgniter", "PostgreSQL", "MongoDB", "Scrum", "SOLID", "CI/CD"]
  },
  {
    role: "Chefe da Seção de Informações Institucionais",
    company: "Universidade Federal de Pelotas",
    tag: "Tempo Integral",
    url: "https://ufpel.edu.br/",
    period: "Jul/2021 – Dez/2024",
    current: false,
    description: [
      "Coordenei o fluxo de informações estratégicas e a extração de dados da universidade, gerando relatórios precisos para órgãos de controle (MEC, TCU).",
      "Fui responsável por estruturar e automatizar o pipeline de alimentação do Portal de Dados Abertos (dados.ufpel.edu.br), garantindo transparência pública e adequação à LGPD."
    ],
    skills: ["Gestão de Dados", "LGPD", "Automação de Relatórios", "SQL", "Liderança Técnica"]
  },
  {
    role: "Engenheiro de Software Backend",
    company: "HOX",
    tag: "Freelance",
    url: "https://hox.rs/",
    period: "Mai/2022 – Abr/2023",
    current: false,
    description: [
      "Desenvolvi novas funcionalidades e mantive as APIs REST de um backend já existente voltado para o sistema de gestão de uma rede de concessionárias de grande porte utilizando PHP e Laravel.",
      "Atuei ativamente no frontend colaborando com a equipe React para resolução de gargalos de interface e integração de dados. Todo o ecossistema operava conteinerizado via Docker com pipelines CI/CD."
    ],
    skills: ["PHP", "Laravel", "PostgreSQL", "React", "Docker", "Gitlab CI/CD", "PHPUnit"]
  },
  {
    role: "Engenheiro de Software Fullstack (Mobile)",
    company: "Partamon",
    tag: "Freelance",
    url: "https://partamon.com/",
    period: "Dez/2014 – Dez/2019",
    current: false,
    description: [
      "Fui o desenvolvedor líder do aplicativo mobile principal da empresa, publicado e consumido ativamente em produção. Construído utilizando a stack Angular e Ionic.",
      "Trabalhei em equipe para estruturar e consumir as APIs backend utilizando Laravel, Express e PostgreSQL, sustentando a lógica de negócios do aplicativo mobile."
    ],
    skills: ["Ionic", "Angular", "Mobile Development", "Laravel", "PostgreSQL", "Docker"]
  },
  {
    role: "Desenvolvedor Mobile App/PWA",
    company: "Santa Transmedia",
    tag: "Freelance",
    url: "https://santatransmedia.com/",
    period: "Fev/2015 – Nov/2017",
    current: false,
    description: [
      "Fui um dos responsáveis pela entrega de múltiplos aplicativos PWA (ex: \"Converse Love\", \"Adesão Faz Bem\", \"Biblia Play\", \"Projeto Comunica\"), atuando diretamente com as equipes de frontend e design.",
      "Realizei o consumo e a integração de dezenas de APIs REST para criar experiências ricas no lado do cliente utilizando Ionic Framework, Apache Cordova e TypeScript."
    ],
    skills: ["Ionic", "PWA", "TypeScript", "Apache Cordova", "Angular", "APIs REST"]
  },
  {
    role: "Desenvolvedor de Software",
    company: "VOIZA",
    tag: "Tempo Integral",
    url: "https://www.voiza.com.br/",
    period: "Jul/2006 – Nov/2008",
    current: false,
    description: [
      "Trilha inicial da carreira atuando no desenvolvimento do sistema ERP proprietário da empresa. Traduzi extensa documentação técnica UML para código de negócios."
    ],
    skills: ["VB6", "Oracle Database", "PostgreSQL", "Modelagem UML", "SVN"]
  }
];
---

<BaseLayout title="Experiência Profissional & Liderança Técnica | Fabrício Scaglioni">
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <div class="glass-card p-6 sm:p-8 mb-10 relative overflow-hidden">
      <div class="flex items-center gap-4 relative">
        <div class="w-12 h-12 rounded-lg border border-white/10 bg-black/40 flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-briefcase text-slate-400 text-xl"></i>
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-display italic tracking-wide text-white">Experiência Profissional</h1>
          <p class="text-slate-500 text-xs mt-1 uppercase tracking-widest font-bold">Minha trajetória como desenvolvedor de sistemas desde 2006</p>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="relative timeline-line pl-8 sm:pl-10 space-y-6">
      {experiences.map((exp) => (
        <div class="relative">
          <!-- Dot -->
          <div class={`absolute -left-[37px] sm:-left-[45px] w-2 h-2 rounded-full border border-slate-700 bg-[#030303] mt-2.5 transition-colors ${exp.current ? 'border-rose-500 bg-rose-500' : ''}`}>
            {exp.current && <div class="w-1 h-1 bg-white rounded-full mx-auto mt-[1px] animate-ping"></div>}
          </div>

          <!-- Card -->
          <div class="glass-card p-6">
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 mb-4 border-b border-white/5 pb-4">
              <div>
                <h3 class="text-xl sm:text-2xl font-display italic tracking-wide text-white">{exp.role}</h3>
                <a href={exp.url} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white text-xs font-bold uppercase tracking-wider transition-colors inline-block mt-1">
                  {exp.company} <span class="text-slate-600 font-medium ml-1">({exp.tag})</span>
                </a>
              </div>
              <span class={`font-mono text-[9px] px-2.5 py-1 rounded-full uppercase tracking-widest border flex-shrink-0 self-start ${exp.current ? 'bg-rose-500/10 text-rose-400 border-rose-500/20' : 'bg-white/5 text-slate-500 border-white/5'}`}>
                {exp.period}
              </span>
            </div>
            <ul class="list-none space-y-3 mb-6">
              {exp.description.map(bullet => (
                <li class="flex items-start gap-3">
                  <span class="text-rose-500 mt-1 text-[10px] shrink-0">■</span>
                  <span class="text-slate-300 text-sm leading-relaxed">{bullet}</span>
                </li>
              ))}
            </ul>
            {exp.skills.length > 0 && (
              <div class="flex flex-wrap gap-1.5 pt-4 border-t border-white/5 border-dashed">
                {exp.skills.map(skill => (
                  <span class="px-2 py-0.5 rounded-md bg-white/5 text-slate-400 text-[10px] uppercase font-bold tracking-wider border border-white/5 hover:border-white/10 transition-colors">
                    {skill}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </article>
</BaseLayout>
