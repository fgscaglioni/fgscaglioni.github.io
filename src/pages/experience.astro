---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

// Data adapted from the markdown source
const experiences = [
  {
    role: "Analista de TI",
    company: "Universidade Federal de Pelotas",
    url: "https://ufpel.edu.br/",
    period: "11/2008 – Atualmente",
    current: true,
    description: "Servidor público, responsável pela manutenção e evolução do sistema acadêmico institucional (GOL → Cobalto). Desenvolvi módulos em PHP/CodeIgniter e iniciativas com NestJS e o aplicativo universitário mobile.",
    skills: ["CodeIgniter", "PHP", "NestJS", "PostgreSQL", "MongoDB", "Redis", "Docker", "Gitlab"]
  },
  {
    role: "Chefe de Seção",
    company: "Universidade Federal de Pelotas",
    url: "https://ufpel.edu.br/",
    period: "07/2021 – 12/2024",
    current: false,
    description: "Coordenei a automatização do fluxo de informações institucionais para o portal de dados abertos (dados.ufpel.edu.br) e forneci relatórios estratégicos para órgãos de controle e gestão.",
    skills: []
  },
  {
    role: "Backend Developer",
    company: "HOX",
    url: "https://hox.rs/",
    period: "Mai/2022 – Abr/2023",
    current: false,
    description: "Desenvolvimento backend em PHP/Laravel para grande concessionária, com entrega de endpoints REST consumidos por aplicativo React. Após entrega, atuei também na interface frontend.",
    skills: ["Laravel", "PostgreSQL", "React", "Gitlab", "Docker"]
  },
  {
    role: "App Developer",
    company: "Partamon",
    url: "https://partamon.com/",
    period: "Dez/2014 – Dez/2019",
    current: false,
    description: "Desenvolvimento do aplicativo mobile da empresa (Angular + Ionic) e APIs backend (PHP/Laravel/PostgreSQL) com suporte de CI/CD e Docker.",
    skills: ["Angular", "Ionic", "PHP", "Laravel", "PostgreSQL", "Docker"]
  },
  {
    role: "Developer",
    company: "Santa Transmedia",
    url: "https://santatransmedia.com/",
    period: "Fev/2015 – Nov/2017",
    current: false,
    description: "Desenvolvimento de PWAs em diversas verticais (\"Converse Love\", \"Adesão Faz Bem\", \"Biblia Play\") utilizando Cordova, Ionic e Angular.",
    skills: ["Apache Cordova", "Ionic", "Angular", "TypeScript"]
  },
  {
    role: "Desenvolvedor",
    company: "VOIZA",
    url: "https://www.voiza.com.br/",
    period: "Jul/2006 – Nov/2008",
    current: false,
    description: "Início de carreira desenvolvendo sistemas em VB6 e Oracle Database, seguindo framework interno e documentação UML.",
    skills: ["Visual Basic", "Oracle", "PostgreSQL", "UML"]
  }
];
---

<BaseLayout title="Experiência | @fgscaglioni">
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <div class="glass rounded-2xl p-8 mb-8 glow-hover relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent pointer-events-none rounded-2xl"></div>
      <div class="flex items-center gap-4 relative">
        <div class="w-12 h-12 rounded-2xl bg-blue-500/20 flex items-center justify-center flex-shrink-0 border border-blue-500/20">
          <i class="fa-solid fa-briefcase text-blue-400 text-xl"></i>
        </div>
        <div>
          <h1 class="text-3xl font-bold gradient-text">Experiência Profissional</h1>
          <p class="text-slate-500 text-sm mt-1">Minha trajetória como desenvolvedor de sistemas desde 2006</p>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="relative timeline-line pl-10 space-y-6">
      {experiences.map((exp) => (
        <div class="relative">
          <!-- Dot -->
          <div class={`absolute -left-10 w-5 h-5 rounded-full border-2 flex items-center justify-center bg-[#0a0e1a] mt-1.5 transition-colors ${exp.current ? 'border-blue-400' : 'border-slate-700'}`}>
            <div class={`w-2 h-2 rounded-full ${exp.current ? 'bg-blue-400 animate-pulse' : 'bg-slate-600'}`}></div>
          </div>

          <!-- Card -->
          <div class="glass rounded-2xl p-5 glow-hover hover:border-blue-500/20 transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-3">
              <div>
                <h3 class="text-white font-bold text-base">{exp.role}</h3>
                <a href={exp.url} target="_blank" rel="noopener noreferrer" class="text-blue-400 text-sm hover:text-blue-300 transition-colors font-medium">
                  {exp.company}
                </a>
              </div>
              <span class={`font-mono text-xs px-2.5 py-1 rounded-lg flex-shrink-0 ${exp.current ? 'bg-green-500/15 text-green-400 border border-green-500/20' : 'bg-white/5 text-slate-500 border border-white/5'}`}>
                {exp.period}
              </span>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{exp.description}</p>
            {exp.skills.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {exp.skills.map(skill => (
                  <span class="px-2 py-0.5 rounded-md bg-white/5 text-slate-400 text-xs border border-white/5 hover:border-white/10 transition-colors">
                    {skill}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </article>
</BaseLayout>
