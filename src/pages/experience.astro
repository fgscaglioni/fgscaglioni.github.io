---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

const experiences = [
  {
    role: "Analista de TI",
    company: "Universidade Federal de Pelotas",
    url: "https://ufpel.edu.br/",
    period: "11/2008 - Atualmente",
    description: "Na UFPel, sou servidor público. Quando entrei para a equipe, era responsável pela manutenção de um sistema legado desenvolvido com PHP, HTML, CSS e banco de dados DB2, conhecido como GOL. Cerca de um ou dois anos depois, comecei a trabalhar com outra equipe para criar o novo sistema acadêmico da instituição. Planejamos bastante e, depois de um tempo, nasceu o projeto Cobalto. Um sistema modular baseado no framework CodeIgniter, desenvolvido com PHP, HTML, CSS e jQuery (alta tecnologia na época). Muitos anos se passaram e o sistema continua crescendo com novos módulos e funcionalidades a cada novo ciclo de sprint. Paralelamente, com outros membros da equipe, iniciamos uma API com Nest.JS com foco na atualização do sistema. Também iniciei aqui o aplicativo da universidade, com informações vitais para os alunos, como notas e registro de frequência.",
    skills: ["CodeIgniter", "CSS", "DB2", "Docker", "Gitlab", "HTML", "JavaScript", "Laravel", "MongoDB", "NestJS", "PHP", "PostgreSQL", "Redis", "UML"]
  },
  {
    role: "Chefe de Seção",
    company: "Universidade Federal de Pelotas",
    url: "https://ufpel.edu.br/",
    period: "07/2021 - 12/2024",
    description: "Como chefe da Seção de Informações Institucionais, fui responsável por coordenar a automatização do fluxo de informações geradas mensalmente, semestralmente e anualmente para o portal de dados abertos da universidade (dados.ufpel.edu.br). Também forneci relatórios aos órgãos de controle e unidades de gestão, mediante solicitação.",
    skills: []
  },
  {
    role: "Backend Developer",
    company: "HOX",
    url: "https://hox.rs/",
    period: "Mai/2022 - Abr/2023",
    description: "Na Hox, comecei como desenvolvedor backend, dando suporte a um sistema usado por uma grande concessionária aqui na minha cidade. Trabalhei com PHP, Laravel Framework, Gitlab, Docker, PostgreSQL e PHP Unit Test. Era responsável pela entrega de endpoints para os desenvolvedores frontend que estavam criando o novo aplicativo React. Depois de um tempo, o frontend foi \"finalizado\" e a equipe responsável pelo projeto do aplicativo foi liberada. Depois disso, fui convidado a tentar resolver alguns problemas na interface, o que fiz sem preocupações. Então, também comecei a desenvolver algumas novas funcionalidades para o aplicativo frontend React.",
    skills: ["Laravel", "PostgreSQL", "React", "Gitlab", "Docker"]
  },
  {
    role: "App Developer",
    company: "Partamon",
    url: "https://partamon.com/",
    period: "Dez/2014 - Dez/2019",
    description: "Nesta função, fui responsável pelo desenvolvimento do aplicativo mobile da empresa. Também trabalhei no backend com um colega para fornecer as APIs usadas no aplicativo. No aplicativo mobile, a pilha era HTML, CSS, Angular e Ionic. No backend, usamos Express, PHP, Laravel Framework e PostgreSQL. Tudo isso com suporte de Git, Docker e CI/CD.",
    skills: ["Laravel", "PHP", "Android", "Ionic", "Gitlab", "Docker"]
  },
  {
    role: "Developer",
    company: "Santa Transmedia",
    url: "https://santatransmedia.com/",
    period: "Fev/2015 - Nov/2017",
    description: "Aqui, eu era o principal responsável pelo desenvolvimento de PWAs. Trabalhamos em diversos projetos diferentes e, em cada um deles, eu utilizava as APIs e apresentava as informações aos usuários. Trabalhei em projetos como \"Converse Love\", \"Adesão Faz Bem\", \"Biblia Play\", \"Projeto Comunica\", entre outros. Para desenvolver esses PWAs, utilizamos Apache Cordova, Ionic Framework, Angular, Typescript, HTML e CSS.",
    skills: ["Gitlab", "Docker"]
  },
  {
    role: "Desenvolvedor",
    company: "VOIZA",
    url: "https://www.voiza.com.br/",
    period: "Jul/2006 - Nov/2008",
    description: "Comecei minha carreira aqui, trabalhando principalmente com VB6, Oracle Database e PostgreSQL. Minha função era seguir o framework de desenvolvimento da empresa. Nessa função, minha função era ler a documentação UML e transformá-la em código VB6.",
    skills: ["Visual Basic", "Oracle", "PostgreSQL", "UML", "Subversion SVN"]
  }
];
---

<BaseLayout title="Experiência | @fgscaglioni">
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article>
    <h1 class="text-4xl font-extrabold mb-8 pb-2 border-b text-gray-900">Experiência</h1>
    
    <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-300 before:to-transparent">
      {experiences.map((exp, index) => (
        <div class="relative flex items-start justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
          <!-- Icon -->
          <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-slate-100 group-[.is-active]:bg-blue-500 text-slate-500 group-[.is-active]:text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 z-10 transition-colors">
            <i class="fa-solid fa-briefcase"></i>
          </div>
          <!-- Content -->
          <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-4 rounded bg-white shadow-sm border border-slate-200">
            <div class="flex flex-col md:flex-row md:items-center justify-between mb-2">
              <h3 class="font-bold text-lg text-slate-900">{exp.role}</h3>
              <time class="text-sm font-medium text-blue-500">{exp.period}</time>
            </div>
            <div class="mb-3 text-slate-600 font-medium">
              <a href={exp.url} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors">
                {exp.company}
              </a>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed mb-4">
              {exp.description}
            </p>
            {exp.skills.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {exp.skills.map(skill => (
                  <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                    {skill}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </article>
</BaseLayout>
