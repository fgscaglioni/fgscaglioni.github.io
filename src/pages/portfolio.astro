---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import PaperCard from "../components/PaperCard.astro";
import PageHeader from "../components/PageHeader.astro";
import { projects } from "../data/portfolioData";
import BulletItem from "../components/BulletItem.astro";


---

<BaseLayout title="Portfólio de Projetos & Publicações Científicas | Fabrício Scaglioni">
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <PageHeader icon="folder-open" title="Portfólio" subtitle="Projetos de Software, mobile e soluções Web em produção" />

    <p class="text-gray-500 text-xs mb-8 ml-1 italic">
      Alguns projetos corporativos sob acordos de confidencialidade (NDA) foram omitidos.
    </p>

    <!-- Projects -->
    <div class="space-y-8">
      {
        projects.map((project) => (
          <PaperCard class=" overflow-hidden">
            <!-- Header Bar -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 px-6 py-4 border-b border-gray-100 bg-gray-50">
              <div>
                <div class="flex items-center gap-3 mb-1">
                  <span class="font-mono text-[9px] px-2 py-0.5 rounded-full border border-gray-200 text-gray-500 uppercase tracking-widest bg-gray-100">
                    {project.year}
                  </span>
                  <span class="text-gray-400 text-xs uppercase tracking-wider">
                    {project.client}
                  </span>
                </div>
                <h2 class="text-2xl font-display italic text-gray-900 tracking-wide">
                  {project.url ? (
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-gray-700 transition-colors"
                    >
                      {project.name}
                      <i class="fa-solid fa-arrow-up-right-from-square text-xs ml-2 opacity-40 hover:opacity-100 transition-opacity" />
                    </a>
                  ) : (
                    project.name
                  )}
                </h2>
              </div>
              <div class="flex flex-wrap gap-1.5 sm:justify-end">
                {project.stack.map((tech) => (
                  <span class="px-2 py-0.5 rounded-md border border-gray-100 bg-gray-50 text-gray-500 text-[10px] uppercase font-bold tracking-wider">
                    {tech}
                  </span>
                ))}
              </div>
            </div>

            <!-- Content -->
            <div class="px-6 py-5">
              <p class="text-gray-700 text-sm leading-relaxed mb-5 border-l-2 border-rose-500 pl-4">
                {project.summary}
              </p>
              <ul class="space-y-2.5 mb-6">
                {project.bullets.map((bullet) => (
                  <BulletItem>{bullet}</BulletItem>
                ))}
              </ul>

              {project.name === "My Safe Back" && (
                <div class="mb-6 pt-2">
                  <a
                    href="https://doi.org/10.1016/j.bjpt.2025.101232"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-gray-700 hover:text-gray-900 transition-colors"
                  >
                    <i class="fa-solid fa-file-pdf text-rose-500" /> Acessar Artigo Publicado (BJPT)
                  </a>
                </div>
              )}

              <!-- Screenshots Gallery -->
              {project.screenshots.length > 0 && (
                <div class="border-t border-gray-100 pt-5">
                  <p class="text-gray-400 text-[10px] uppercase tracking-widest font-bold mb-4">
                    Screenshots
                  </p>
                  <div
                    class={`flex gap-3 overflow-x-auto pb-2 ${
                      project.screenshotType === "mobile"
                        ? "items-end"
                        : "items-start"
                    }`}
                  >
                    {project.screenshots.map((img: any, i) => (
                      <div
                        class={`flex-shrink-0 border border-gray-100 rounded-lg overflow-hidden transition-all duration-200 hover:border-white/20 ${
                          project.screenshotType === "mobile"
                            ? "w-32"
                            : "w-64"
                        }`}
                      >
                        <img
                          src={img.src}
                          alt={`${project.name} screenshot ${i + 1}`}
                          class="w-full h-auto object-cover grayscale hover:grayscale-0 transition-all duration-300"
                          loading="lazy"
                        />
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </PaperCard>
        ))
      }
    </div>
  </article>
</BaseLayout>
