---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import { changelogData } from "../data/changelogData";
import PaperCard from "../components/PaperCard.astro";
import PageHeader from "../components/PageHeader.astro";
import BulletItem from "../components/BulletItem.astro";
---

<BaseLayout title="Histórico de Modificações | Fabrício Scaglioni">
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <PageHeader icon="clock-rotate-left" title="Changelog" subtitle="Histórico de modificações e evolução do site" />

    <!-- Timeline of Changes -->
    <div class="relative pl-6 sm:pl-8 border-l border-gray-100 space-y-12">
      {
        changelogData.map((item) => (
          <div class="relative">
            <!-- Position marker -->
            <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4 h-4 rounded-full border-2 border-slate-900 bg-rose-500 flex items-center justify-center">
              <span class="w-1.5 h-1.5 bg-black rounded-full" />
            </div>

            <!-- Card Content -->
            <PaperCard class=" p-6">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3 pb-3 border-b border-gray-100">
                <div>
                  <span class="font-mono text-[10px] px-2 py-0.5 rounded-md border border-gray-200 bg-gray-100 text-gray-700 font-bold uppercase tracking-wider">
                    {item.version}
                  </span>
                  <h2 class="text-xl font-display italic text-gray-900 tracking-wide mt-1.5">
                    {item.title}
                  </h2>
                </div>
                <time class="text-gray-400 text-[10px] font-mono uppercase tracking-wider whitespace-nowrap">
                  {item.date}
                </time>
              </div>

              <p class="text-gray-700 text-xs sm:text-sm mb-4 leading-relaxed font-light">
                {item.description}
              </p>

              <ul class="space-y-2.5">
                {item.changes.map((change) => (
                  <BulletItem>{change}</BulletItem>
                ))}
              </ul>
            </PaperCard>
          </div>
        ))
      }
    </div>
  </article>
</BaseLayout>
