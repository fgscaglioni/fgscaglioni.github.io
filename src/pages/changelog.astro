---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import { changelogData } from "../data/changelogData";
---

<BaseLayout title="Histórico de Modificações | Fabrício Scaglioni">
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <div class="glass-card p-6 sm:p-8 mb-8 relative overflow-hidden">
      <div class="flex items-center gap-4 relative">
        <div class="w-12 h-12 rounded-lg border border-white/10 bg-black/40 flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-clock-rotate-left text-slate-400 text-xl"></i>
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-display italic tracking-wide text-white">Changelog</h1>
          <p class="text-slate-500 text-xs mt-1 uppercase tracking-widest font-bold">Histórico de modificações e evolução do site</p>
        </div>
      </div>
    </div>

    <!-- Timeline of Changes -->
    <div class="relative pl-6 sm:pl-8 border-l border-white/5 space-y-12">
      {
        changelogData.map((item) => (
          <div class="relative">
            <!-- Position marker -->
            <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4 h-4 rounded-full border-2 border-slate-900 bg-rose-500 flex items-center justify-center">
              <span class="w-1.5 h-1.5 bg-black rounded-full" />
            </div>

            <!-- Card Content -->
            <div class="glass-card p-6">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3 pb-3 border-b border-white/5">
                <div>
                  <span class="font-mono text-[10px] px-2 py-0.5 rounded-md border border-white/10 bg-black/40 text-slate-300 font-bold uppercase tracking-wider">
                    {item.version}
                  </span>
                  <h2 class="text-xl font-display italic text-white tracking-wide mt-1.5">
                    {item.title}
                  </h2>
                </div>
                <time class="text-slate-500 text-[10px] font-mono uppercase tracking-wider whitespace-nowrap">
                  {item.date}
                </time>
              </div>

              <p class="text-slate-300 text-xs sm:text-sm mb-4 leading-relaxed font-light">
                {item.description}
              </p>

              <ul class="space-y-2.5">
                {item.changes.map((change) => (
                  <li class="flex items-start gap-3">
                    <span class="text-rose-500 mt-1 text-[8px] shrink-0">
                      ■
                    </span>
                    <span class="text-slate-400 text-xs sm:text-sm leading-relaxed">
                      {change}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </article>
</BaseLayout>
