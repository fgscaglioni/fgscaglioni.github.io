---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import PaperCard from "../components/PaperCard.astro";
import PageHeader from "../components/PageHeader.astro";
import { articles, dissertations } from "../data/downloadsData";
import SectionHeader from "../components/SectionHeader.astro";




---

<BaseLayout title="Downloads de Publicações Científicas | Fabrício Scaglioni">
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <PageHeader icon="download" title="Downloads" subtitle="Publicações acadêmicas, artigos e dissertações" />

    <!-- Articles -->
    <section class="mb-10">
      <SectionHeader icon="file-pdf" title="Artigos Publicados" />
      <div class="grid md:grid-cols-2 gap-5">
        {
          articles.map((category) => (
            <PaperCard class=" overflow-hidden">
              <div class="px-5 py-3 border-b border-gray-100 flex items-center gap-2 bg-gray-50">
                <i class={`fa-solid ${category.icon} ${category.color} text-sm`} />
                <h3 class="font-bold text-gray-500 uppercase tracking-wider text-[9px]">{category.type}</h3>
              </div>
              <div class="p-5 space-y-6">
                {category.items.map((item) => (
                  <div>
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block text-gray-800 hover:text-gray-900 font-serif text-lg leading-snug transition-colors mb-2"
                    >
                      {item.title}
                    </a>
                    <div class="flex flex-wrap items-center gap-3 mt-1 text-[10px] font-mono text-gray-400">
                      <span>{item.month}/{item.year}</span>
                      {item.event && (
                        <>
                          <span>/</span>
                          {item.event_url ? (
                            <a href={item.event_url} target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors flex items-center gap-1">
                              {item.event}
                              <i class="fa-solid fa-arrow-up-right-from-square text-[8px]" />
                            </a>
                          ) : (
                            <span>{item.event}</span>
                          )}
                        </>
                      )}
                      <span class="px-2 py-0.5 rounded border border-gray-200 bg-gray-50 text-gray-500 font-bold ml-auto">
                        {item.badge}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </PaperCard>
          ))
        }
      </div>
    </section>

    <!-- Dissertation -->
    <section>
      <SectionHeader icon="book" title="Dissertação de Mestrado" />
      {
        dissertations.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group paper-card p-6 flex flex-col sm:flex-row items-center gap-6 transition-all duration-300"
          >
            <div class="w-16 h-20 rounded-lg border border-gray-200 bg-gray-100 flex items-center justify-center flex-shrink-0 group-hover:border-white/20 transition-colors">
              <i class="fa-solid fa-book-open text-gray-400 text-2xl group-hover:text-gray-800 transition-colors" />
            </div>
            <div class="flex-1 min-w-0 text-center sm:text-left">
              <p class="text-[9px] font-mono font-bold uppercase tracking-widest text-gray-400 mb-1">ANO: {item.year}</p>
              <h3 class="text-gray-800 font-serif text-xl leading-snug group-hover:text-gray-900 transition-colors">{item.title}</h3>
              <div class="flex items-center justify-center sm:justify-end gap-2 mt-4 text-gray-500 text-xs font-bold uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span>Acessar repositório</span>
                <i class="fa-solid fa-arrow-right text-sm" />
              </div>
            </div>
          </a>
        ))
      }
    </section>
  </article>
</BaseLayout>
