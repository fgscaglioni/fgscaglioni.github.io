---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

const articles = [
  {
    type: "Autor",
    icon: "fa-pen-nib",
    color: "text-slate-400",
    bgColor: "bg-[#050505] border-slate-800",
    items: [
      {
        title:
          "Enrollment Recommendation System based on Student Profile and Progress",
        url: "https://doi.org/10.1109/LACLO56648.2022.10013424",
        date: "Jan/2023",
        badge: "IEEE",
      },
    ],
  },
  {
    type: "Coautor",
    icon: "fa-people-group",
    color: "text-slate-400",
    bgColor: "bg-[#050505] border-slate-800",
    items: [
      {
        title:
          "Effectiveness of an app-delivered, self-management exercise program in public safety workers with chronic low back pain: a randomized controlled trial",
        url: "/public/papers/1-s2.0-S1413355525000619-main.pdf",
        date: "Jul/2025",
        badge: "PDF",
      },
      {
        title:
          "Effectiveness of m-health-based core strengthening exercise and health education for public safety workers with chronic non-specific low back pain: study protocol for a superiority randomized controlled trial (SAFEBACK)",
        url: "/public/papers/s13063-023-07833-9.pdf",
        date: "Dez/2023",
        badge: "PDF",
      },
    ],
  },
];

const dissertations = [
  {
    title:
      "Sistema de Recomendação de Matrículas a partir do Perfil e do Progresso dos Estudantes no Contexto de Campus Inteligente",
    url: "http://guaiaca.ufpel.edu.br/xmlui/handle/prefix/12891",
    type: "Dissertação de Mestrado",
    year: "2021",
  },
];
---

<BaseLayout title="Downloads | @fgscaglioni">
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <article class="pt-8 pb-16">
      <!-- Page Header -->
      <div
        class="brutalist-card p-8 mb-12 sharp-hover relative overflow-hidden"
      >
        <div class="flex items-center gap-4 relative">
          <div
            class="w-12 h-12 border border-slate-700 bg-[#0a0a0a] flex items-center justify-center flex-shrink-0"
          >
            <i class="fa-solid fa-download text-slate-400 text-xl"></i>
          </div>
          <div>
            <h1 class="text-4xl font-display italic tracking-wide text-white">
              Downloads
            </h1>
            <p
              class="text-slate-500 text-sm mt-1 uppercase tracking-widest font-bold"
            >
              Publicações acadêmicas, artigos e dissertações
            </p>
          </div>
        </div>
      </div>

      <!-- Articles -->
      <section class="mb-12">
        <div
          class="flex items-center gap-3 mb-6 border-b border-slate-800 pb-3"
        >
          <div
            class="w-8 h-8 border border-slate-700 flex items-center justify-center"
          >
            <i class="fa-solid fa-file-pdf text-slate-400 text-xs"></i>
          </div>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Artigos Publicados
          </h2>
        </div>
        <div class="grid lg:grid-cols-2 gap-5">
          {
            articles.map((category) => (
              <div class="brutalist-card">
                <div
                  class={`px-5 py-3 border-b border-slate-800 flex items-center gap-2 ${category.bgColor}`}
                >
                  <i
                    class={`fa-solid ${category.icon} ${category.color} text-sm`}
                  />
                  <h3 class="font-bold text-slate-300 uppercase tracking-wider text-[10px]">
                    {category.type}
                  </h3>
                </div>
                <div class="p-5 space-y-6">
                  {category.items.map((item) => (
                    <div class="group">
                      <a
                        href={item.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block text-slate-300 hover:text-white font-serif text-lg leading-snug transition-colors mb-2 group-hover:underline decoration-rose-500/50 underline-offset-4"
                      >
                        {item.title}
                      </a>
                      <div class="flex items-center gap-3">
                        <span class="text-[10px] font-mono uppercase font-bold text-slate-500">
                          {item.date}
                        </span>
                        <span class="px-2 py-0.5 border border-slate-700 bg-[#050505] text-slate-400 text-[10px] uppercase font-bold tracking-wider">
                          {item.badge}
                        </span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Dissertation -->
      <section>
        <div
          class="flex items-center gap-3 mb-6 border-b border-slate-800 pb-3"
        >
          <div
            class="w-8 h-8 border border-slate-700 flex items-center justify-center"
          >
            <i class="fa-solid fa-book text-slate-400 text-xs"></i>
          </div>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Dissertação de Mestrado
          </h2>
        </div>
        {
          dissertations.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group brutalist-card p-6 sharp-hover flex flex-col sm:flex-row items-start gap-6 transition-all duration-300"
            >
              <div class="w-16 h-20 border border-slate-700 bg-slate-900 flex items-center justify-center flex-shrink-0 group-hover:border-slate-400 transition-colors shadow-[4px_4px_0px_#1a1a1a] group-hover:shadow-[4px_4px_0px_#333]">
                <i class="fa-solid fa-book-open text-slate-500 text-2xl group-hover:text-slate-200 transition-colors" />
              </div>
              <div class="flex-1 min-w-0 pt-1">
                <p class="text-[10px] font-mono font-bold uppercase tracking-widest text-slate-500 mb-2">
                  ANO: {item.year}
                </p>
                <h3 class="text-slate-300 font-serif text-xl leading-snug group-hover:text-white transition-colors">
                  {item.title}
                </h3>
                <div class="flex items-center justify-end gap-2 mt-4 text-slate-400 text-xs font-bold uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                  <span>Acessar repositório</span>
                  <i class="fa-solid fa-arrow-right text-sm" />
                </div>
              </div>
            </a>
          ))
        }
      </section>
    </article>
  </article>
</BaseLayout>
