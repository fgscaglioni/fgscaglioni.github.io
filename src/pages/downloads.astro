---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";

const articles = [
  {
    type: "Autor",
    icon: "fa-pen-nib",
    color: "text-slate-400",
    bgColor: "bg-white/5 border-white/5",
    items: [
      {
        title:
          "Enrollment Recommendation System based on Student Profile and Progress",
        url: "https://doi.org/10.1109/LACLO56648.2022.10013424",
        event: "LACLO",
        year: "2023",
        month: "Jan",
        event_url: "https://ieeexplore.ieee.org/document/10013424",
        badge: "IEEE",
      },
      {
        title: "Plataforma de Interação Digital no Contexto de Campus Inteligente",
        url: "https://anais-siiepe.ufpel.edu.br/2020/CE_03692.pdf",
        event: "SIIEPE",
        year: "2020",
        month: "Nov",
        event_url: "https://anais-siiepe.ufpel.edu.br/2020/index.html",
        badge: "UFPel",
      }
    ],
  },
  {
    type: "Coautor",
    icon: "fa-people-group",
    color: "text-slate-400",
    bgColor: "bg-white/5 border-white/5",
    items: [
      {
        title:
          "Effectiveness of an app-delivered, self-management exercise program in public safety workers with chronic low back pain: a randomized controlled trial",
        url: "/public/papers/1-s2.0-S1413355525000619-main.pdf",
        year: "2025",
        month: "Jul",
        badge: "PDF",
      },
      {
        title:
          "Effectiveness of m-health-based core strengthening exercise and health education for public safety workers with chronic non-specific low back pain: study protocol for a superiority randomized controlled trial (SAFEBACK)",
        url: "/public/papers/s13063-023-07833-9.pdf",
        year: "2023",
        month: "Dez",
        badge: "PDF",
      },
    ],
  },
];

const dissertations = [
  {
    title:
      "Sistema de Recomendação de Matrículas a partir do Perfil e do Progresso dos Estudantes no Contexto de Campus Inteligente",
    url: "http://guaiaca.ufpel.edu.br/xmlui/handle/prefix/12891",
    type: "Dissertação de Mestrado",
    year: "2021",
  },
];
---

<BaseLayout title="Downloads de Publicações Científicas | Fabrício Scaglioni">
  <Navbar slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <div class="glass-card p-6 sm:p-8 mb-8 relative overflow-hidden">
      <div class="flex items-center gap-4 relative">
        <div class="w-12 h-12 rounded-lg border border-white/10 bg-black/40 flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-download text-slate-400 text-xl"></i>
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-display italic tracking-wide text-white">Downloads</h1>
          <p class="text-slate-500 text-xs mt-1 uppercase tracking-widest font-bold">Publicações acadêmicas, artigos e dissertações</p>
        </div>
      </div>
    </div>

    <!-- Articles -->
    <section class="mb-10">
      <div class="flex items-center gap-3 mb-6 border-b border-white/5 pb-3">
        <i class="fa-solid fa-file-pdf text-slate-400 text-sm"></i>
        <h2 class="text-2xl font-display italic text-white tracking-wide">Artigos Publicados</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-5">
        {
          articles.map((category) => (
            <div class="glass-card overflow-hidden">
              <div class="px-5 py-3 border-b border-white/5 flex items-center gap-2 bg-white/5">
                <i class={`fa-solid ${category.icon} ${category.color} text-sm`} />
                <h3 class="font-bold text-slate-400 uppercase tracking-wider text-[9px]">{category.type}</h3>
              </div>
              <div class="p-5 space-y-6">
                {category.items.map((item) => (
                  <div>
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block text-slate-200 hover:text-white font-serif text-lg leading-snug transition-colors mb-2"
                    >
                      {item.title}
                    </a>
                    <div class="flex flex-wrap items-center gap-3 mt-1 text-[10px] font-mono text-slate-500">
                      <span>{item.month}/{item.year}</span>
                      {item.event && (
                        <>
                          <span>/</span>
                          {item.event_url ? (
                            <a href={item.event_url} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors flex items-center gap-1">
                              {item.event}
                              <i class="fa-solid fa-arrow-up-right-from-square text-[8px]" />
                            </a>
                          ) : (
                            <span>{item.event}</span>
                          )}
                        </>
                      )}
                      <span class="px-2 py-0.5 rounded border border-white/10 bg-white/5 text-slate-400 font-bold ml-auto">
                        {item.badge}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Dissertation -->
    <section>
      <div class="flex items-center gap-3 mb-6 border-b border-white/5 pb-3">
        <i class="fa-solid fa-book text-slate-400 text-sm"></i>
        <h2 class="text-2xl font-display italic text-white tracking-wide">Dissertação de Mestrado</h2>
      </div>
      {
        dissertations.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group glass-card p-6 flex flex-col sm:flex-row items-center gap-6 transition-all duration-300"
          >
            <div class="w-16 h-20 rounded-lg border border-white/10 bg-black/40 flex items-center justify-center flex-shrink-0 group-hover:border-white/20 transition-colors">
              <i class="fa-solid fa-book-open text-slate-500 text-2xl group-hover:text-slate-200 transition-colors" />
            </div>
            <div class="flex-1 min-w-0 text-center sm:text-left">
              <p class="text-[9px] font-mono font-bold uppercase tracking-widest text-slate-500 mb-1">ANO: {item.year}</p>
              <h3 class="text-slate-200 font-serif text-xl leading-snug group-hover:text-white transition-colors">{item.title}</h3>
              <div class="flex items-center justify-center sm:justify-end gap-2 mt-4 text-slate-400 text-xs font-bold uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <span>Acessar repositório</span>
                <i class="fa-solid fa-arrow-right text-sm" />
              </div>
            </div>
          </a>
        ))
      }
    </section>
  </article>
</BaseLayout>
