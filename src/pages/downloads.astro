---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

const articles = [
  {
    type: "Autor",
    icon: "fa-pen-nib",
    color: "text-blue-400",
    bgColor: "bg-blue-500/15 border-blue-500/20",
    items: [
      {
        title:
          "Enrollment Recommendation System based on Student Profile and Progress",
        url: "https://doi.org/10.1109/LACLO56648.2022.10013424",
        date: "Jan/2023",
        badge: "IEEE",
      },
    ],
  },
  {
    type: "Coautor",
    icon: "fa-people-group",
    color: "text-indigo-400",
    bgColor: "bg-indigo-500/15 border-indigo-500/20",
    items: [
      {
        title:
          "Effectiveness of an app-delivered, self-management exercise program in public safety workers with chronic low back pain: a randomized controlled trial",
        url: "/public/papers/1-s2.0-S1413355525000619-main.pdf",
        date: "Jul/2025",
        badge: "PDF",
      },
      {
        title:
          "Effectiveness of m-health-based core strengthening exercise and health education for public safety workers with chronic non-specific low back pain: study protocol for a superiority randomized controlled trial (SAFEBACK)",
        url: "/public/papers/s13063-023-07833-9.pdf",
        date: "Dez/2023",
        badge: "PDF",
      },
    ],
  },
];

const dissertations = [
  {
    title:
      "Sistema de Recomendação de Matrículas a partir do Perfil e do Progresso dos Estudantes no Contexto de Campus Inteligente",
    url: "http://guaiaca.ufpel.edu.br/xmlui/handle/prefix/12891",
    type: "Dissertação de Mestrado",
    year: "2021",
  },
];
---

<BaseLayout title="Downloads | @fgscaglioni">
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article class="pt-8 pb-16">
    <!-- Page Header -->
    <div class="glass rounded-2xl p-8 mb-8 glow-hover relative overflow-hidden">
      <div
        class="absolute inset-0 bg-gradient-to-br from-green-500/5 to-transparent pointer-events-none rounded-2xl"
      >
      </div>
      <div class="flex items-center gap-4 relative">
        <div
          class="w-12 h-12 rounded-2xl bg-green-500/20 flex items-center justify-center flex-shrink-0 border border-green-500/20"
        >
          <i class="fa-solid fa-download text-green-400 text-xl"></i>
        </div>
        <div>
          <h1 class="text-3xl font-bold gradient-text">Downloads</h1>
          <p class="text-slate-500 text-sm mt-1">
            Publicações acadêmicas, artigos e dissertações disponíveis
          </p>
        </div>
      </div>
    </div>

    <!-- Articles -->
    <section class="mb-8">
      <div class="flex items-center gap-3 mb-5">
        <div
          class="w-8 h-8 rounded-lg bg-red-500/20 flex items-center justify-center"
        >
          <i class="fa-solid fa-file-pdf text-red-400 text-sm"></i>
        </div>
        <h2 class="text-lg font-bold text-white">Artigos Publicados</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-5">
        {
          articles.map((category) => (
            <div class="glass rounded-2xl overflow-hidden">
              <div
                class={`px-5 py-3 border-b border-white/5 flex items-center gap-2 ${category.bgColor} border rounded-t-2xl`}
              >
                <i
                  class={`fa-solid ${category.icon} ${category.color} text-sm`}
                />
                <h3 class="font-semibold text-slate-200 text-sm">
                  {category.type}
                </h3>
              </div>
              <div class="p-4 space-y-4">
                {category.items.map((item) => (
                  <div class="group">
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block text-blue-400 hover:text-blue-300 font-medium text-sm leading-snug transition-colors mb-1.5 group-hover:underline"
                    >
                      {item.title}
                    </a>
                    <div class="flex items-center gap-2">
                      <span class="text-xs font-mono text-slate-600">
                        {item.date}
                      </span>
                      <span class="px-1.5 py-0.5 rounded bg-white/5 text-slate-500 text-xs border border-white/5">
                        {item.badge}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Dissertation -->
    <section>
      <div class="flex items-center gap-3 mb-5">
        <div
          class="w-8 h-8 rounded-lg bg-blue-500/20 flex items-center justify-center"
        >
          <i class="fa-solid fa-book text-blue-400 text-sm"></i>
        </div>
        <h2 class="text-lg font-bold text-white">Dissertação de Mestrado</h2>
      </div>
      {
        dissertations.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group glass rounded-2xl p-6 hover:border-blue-500/30 glow-hover flex items-start gap-5 transition-all duration-300"
          >
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-blue-500/30 transition-colors border border-blue-500/20">
              <i class="fa-solid fa-book-open text-blue-400 text-lg" />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-mono text-slate-600 mb-1">
                {item.type} · {item.year}
              </p>
              <h3 class="text-slate-200 font-semibold leading-snug group-hover:text-white transition-colors">
                {item.title}
              </h3>
              <div class="flex items-center gap-1 mt-2 text-blue-400 text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <span>Acessar repositório</span>
                <i class="fa-solid fa-arrow-up-right-from-square text-xs" />
              </div>
            </div>
          </a>
        ))
      }
    </section>
  </article>
</BaseLayout>
