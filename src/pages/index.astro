---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import StackList from "../components/StackList.astro";
---

<BaseLayout
  title="Fabrício Scaglioni | Engenheiro de Software Sênior & Doutorando em IA"
>
  <Navbar slot="header" />

  <article class="pt-8 pb-4">
    <!-- Hero Section -->
    <section class="glass-card p-6 sm:p-8 mb-6 relative overflow-hidden">
      <!-- Light aura inside card -->
      <div
        class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"
      >
      </div>

      <div
        class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-6 relative"
      >
        <!-- Avatar -->
        <div class="relative flex-shrink-0">
          <img
            src="https://gravatar.com/avatar/556a14540bc4ab41d65b17218d498fd9d628698736378f62deb6e8f0849a5376"
            alt="Fabrício Scaglioni"
            class="relative w-24 h-24 rounded-full object-cover border border-white/10 shadow-xl transition-transform duration-500 hover:scale-105"
          />
        </div>
        <!-- Info -->
        <div class="flex-grow">
          <div class="flex flex-col sm:flex-row items-center gap-3 mb-2">
            <h1
              class="text-3xl sm:text-4xl text-white font-display italic tracking-wide"
            >
              Fabrício Scaglioni
            </h1>
            <span
              class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 text-emerald-400 text-[9px] uppercase font-bold tracking-wider"
            >
              <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-ping"
              ></span> Disponível
            </span>
          </div>
          <!-- Positioning Tagline -->
          <p
            class="text-slate-400 text-sm mb-4 font-mono uppercase tracking-wider leading-relaxed"
          >
            Engenheiro de Software Sênior&nbsp;·&nbsp;Fullstack &amp;
            Mobile&nbsp;·&nbsp;Pesquisador em IA
          </p>
          <!-- Social Links -->
          <div
            class="flex flex-wrap items-center justify-center sm:justify-start gap-2"
          >
            <a
              href="https://www.linkedin.com/in/fgscaglioni/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-white/10 bg-white/5 hover:bg-white hover:text-black text-xs font-bold uppercase tracking-wider transition-all duration-300"
            >
              <i class="fa-brands fa-linkedin"></i> LinkedIn
            </a>
            <a
              href="http://github.com/fgscaglioni/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-white/10 bg-white/5 hover:bg-white hover:text-black text-xs font-bold uppercase tracking-wider transition-all duration-300"
            >
              <i class="fa-brands fa-github"></i> GitHub
            </a>
            <a
              href="https://medium.com/@fgscaglioni"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-white/10 bg-white/5 hover:bg-white hover:text-black text-xs font-bold uppercase tracking-wider transition-all duration-300"
            >
              <i class="fa-brands fa-medium"></i> Medium
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- About + Technical Approach side by side on desktop, stacked on mobile -->
    <div class="grid md:grid-cols-2 gap-6 mb-6">
      <section class="glass-card p-6">
        <div class="flex items-center gap-3 mb-4 border-b border-white/5 pb-3">
          <i class="fa-solid fa-user text-slate-400 text-sm"></i>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Sobre mim
          </h2>
        </div>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-rose-500 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium">+15 anos</strong> atuando em
              todo o ciclo de desenvolvimento — planejamento, arquitetura, frontend
              e backend.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium"
                >Doutorando em Ciência da Computação</strong
              > (UFPel), pesquisando <strong class="text-white font-medium"
                >Inteligência Artificial aplicada à Educação</strong
              >.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              Experiência em escalar sistemas em produção — de aplicativos com <strong
                class="text-white font-medium">+2k usuários</strong
              > a APIs institucionais de alta escala.
            </span>
          </li>
        </ul>
      </section>

      <section class="glass-card p-6">
        <div class="flex items-center gap-3 mb-4 border-b border-white/5 pb-3">
          <i class="fa-solid fa-code text-slate-400 text-sm"></i>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Competências Chave
          </h2>
        </div>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-rose-500 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium"
                >Arquitetura de Software</strong
              > — design e implementação de APIs REST, sistemas containerizados com
              Docker e pipelines CI/CD.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium"
                >Desenvolvimento Fullstack</strong
              > — Laravel, NestJS, Angular, Ionic e PostgreSQL como stacks principais.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium">Pesquisa em ML/IA</strong> —
              modelos preditivos educacionais, SLMs e revisões sistemáticas publicadas
              em periódicos internacionais.
            </span>
          </li>
        </ul>
      </section>
    </div>

    <!-- Stack Section -->
    <section class="mb-8">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px bg-white/10 flex-grow"></div>
        <h2
          class="text-2xl font-display italic text-white tracking-widest px-4"
        >
          Stack & Tecnologias
        </h2>
        <div class="h-px bg-white/10 flex-grow"></div>
      </div>
      <StackList />
    </section>

    <!-- Education + Languages -->
    <div class="grid md:grid-cols-2 gap-6">
      <section class="glass-card p-6">
        <div class="flex items-center gap-3 mb-4 border-b border-white/5 pb-3">
          <i class="fa-solid fa-graduation-cap text-slate-400 text-sm"></i>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Formação Acadêmica
          </h2>
        </div>
        <div class="space-y-4">
          {
            [
              {
                inst: "UFPel",
                href: "https://institucional.ufpel.edu.br/cursos/cod/8102",
                level: "Doutorado em Ciência da Computação",
                period: "2024 - Cursando",
                icon: "fa-circle-dot",
              },
              {
                inst: "i9",
                href: "#",
                level: "Pós-Graduação em Direito Público",
                period: "2024",
                icon: "fa-square",
              },
              {
                inst: "UFPel",
                href: "https://institucional.ufpel.edu.br/cursos/cod/7057",
                level: "Mestrado em Ciência da Computação",
                period: "2019 - 2021",
                icon: "fa-circle-dot",
              },
              {
                inst: "UniSenac",
                href: "https://www.senacrs.com.br/unidade/78",
                level: "Especialização em Gerenciamento de Projetos",
                period: "2009 - 2010",
                icon: "fa-square",
              },
              {
                inst: "UniSenac",
                href: "https://www.senacrs.com.br/unidade/78",
                level: "Tecnólogo em Análise e Desenvolvimento de Sistemas",
                period: "2005 - 2007",
                icon: "fa-square",
              },
            ].map((item) => (
              <div class="flex items-start gap-3">
                <div class="mt-1 flex-shrink-0">
                  <i class={`fa-solid ${item.icon} text-[8px] text-rose-500`} />
                </div>
                <div>
                  <a
                    href={item.href}
                    target="_blank"
                    class="text-slate-200 text-sm font-medium hover:text-white transition-colors"
                  >
                    {item.inst}
                  </a>
                  <p class="text-slate-400 font-light text-xs">{item.level}</p>
                  <p class="text-slate-500 text-[10px] font-mono mt-0.5 tracking-wider">
                    {item.period}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <div class="space-y-6 flex flex-col justify-between">
        <section class="glass-card p-6 flex-grow">
          <div
            class="flex items-center gap-3 mb-4 border-b border-white/5 pb-3"
          >
            <i class="fa-solid fa-globe text-slate-400 text-sm"></i>
            <h2 class="text-2xl font-display italic text-white tracking-wide">
              Idiomas
            </h2>
          </div>
          <div class="space-y-3">
            {
              [
                {
                  lang: "Português",
                  level: "Nativo",
                  pct: 100,
                },
                {
                  lang: "Inglês",
                  level: "Intermediário (Limited Working)",
                  pct: 65,
                },
                {
                  lang: "Espanhol",
                  level: "Básico (Elementary)",
                  pct: 35,
                },
                {
                  lang: "Francês",
                  level: "Básico (Elementary)",
                  pct: 25,
                },
              ].map((item) => (
                <div>
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-xs text-slate-300 font-medium">
                      {item.lang}
                    </span>
                    <span class="text-[10px] font-mono text-slate-500 uppercase tracking-widest">
                      {item.level}
                    </span>
                  </div>
                  <div class="w-full bg-[#050505]/40 border border-white/5 rounded-full h-1.5">
                    <div
                      class="bg-white/80 rounded-full h-full"
                      style={`width: ${item.pct}%`}
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <section class="glass-card p-6 flex-grow">
          <div
            class="flex items-center gap-3 mb-4 border-b border-white/5 pb-3"
          >
            <i class="fa-solid fa-certificate text-slate-400 text-sm"></i>
            <h2 class="text-2xl font-display italic text-white tracking-wide">
              Certificações
            </h2>
          </div>
          <div class="space-y-3">
            {
              [
                {
                  name: "OFICIAL EXIN PDPF",
                  details: "Privacy & Data Protection Foundation EAD",
                },
                {
                  name: "LGPD",
                  details: "Fundamentos da Lei Geral de Proteção de Dados",
                },
                { name: "HTML5", details: "W3C / Desenvolvimento Web" },
                {
                  name: "Angular 2 Fundamentals",
                  details: "TypeScript Framework Core",
                },
                {
                  name: "Ionic 3",
                  details: "Desenvolvimento Híbrido Intermediário",
                },
              ].map((cert) => (
                <div class="flex items-start gap-2">
                  <i class="fa-solid fa-shield-halved text-[8px] text-rose-500 mt-1.5" />
                  <div>
                    <h3 class="text-slate-200 text-xs font-medium">
                      {cert.name}
                    </h3>
                    <p class="text-slate-400 font-light text-[10px]">
                      {cert.details}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>
