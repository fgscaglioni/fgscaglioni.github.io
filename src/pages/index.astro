---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import StackList from "../components/StackList.astro";
---

<BaseLayout>
  <Sidebar slot="sidebar" />
  <Header slot="header" />

  <article class="dot-grid pt-8 pb-4">
    <!-- Hero Section -->
    <section
      class="brutalist-card p-8 mb-8 sharp-hover relative overflow-hidden"
    >
      <div class="flex flex-col sm:flex-row items-start gap-6 relative">
        <!-- Avatar -->
        <div class="relative flex-shrink-0 group">
          <img
            src="https://gravatar.com/avatar/556a14540bc4ab41d65b17218d498fd9d628698736378f62deb6e8f0849a5376"
            alt="Fabrício Scaglioni"
            class="relative w-24 h-24 object-cover border-2 border-slate-700 group-hover:border-slate-300 shadow-[4px_4px_0px_#111] filter grayscale group-hover:grayscale-0 transition-all duration-300"
          />
        </div>
        <!-- Info -->
        <div class="flex-grow">
          <div class="flex items-center gap-3 mb-1">
            <h1 class="text-4xl accent-text font-display italic tracking-wide">
              @fgscaglioni
            </h1>
            <span
              class="inline-flex items-center gap-1.5 px-2 py-0.5 border border-slate-600 bg-slate-800/50 text-slate-300 text-[10px] uppercase font-bold tracking-wider"
            >
              <span class="w-1.5 h-1.5 bg-rose-500 animate-pulse"></span> Disponível
            </span>
          </div>
          <!-- Positioning Tagline -->
          <p class="text-slate-300 font-medium mb-1">Fabrício Scaglioni</p>
          <p
            class="text-slate-500 text-sm mb-5 font-mono uppercase tracking-widest"
          >
            Engenheiro de Software Sênior&nbsp;·&nbsp;Fullstack &amp;
            Mobile&nbsp;·&nbsp;Pesquisador em IA
          </p>
          <!-- Social Links: Primary -->
          <div class="flex flex-wrap items-center gap-2">
            <a
              href="https://www.linkedin.com/in/fgscaglioni/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 border border-slate-500 bg-[#0a0a0a] hover:bg-white/5 hover:border-slate-300 text-slate-200 hover:text-white text-xs font-bold uppercase tracking-wider transition-all duration-200"
            >
              <i class="fa-brands fa-linkedin"></i> LinkedIn
            </a>
            <a
              href="http://github.com/fgscaglioni/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 border border-slate-500 bg-[#0a0a0a] hover:bg-white/5 hover:border-slate-300 text-slate-200 hover:text-white text-xs font-bold uppercase tracking-wider transition-all duration-200"
            >
              <i class="fa-brands fa-github"></i> GitHub
            </a>
            <a
              href="https://medium.com/@fgscaglioni"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 border border-slate-700 bg-[#0a0a0a] hover:bg-white/5 hover:border-slate-500 text-slate-400 hover:text-white text-xs font-bold uppercase tracking-wider transition-all duration-200"
            >
              <i class="fa-brands fa-medium"></i> Medium
            </a>
            <!-- Secondary / Personal -->
            <div class="h-4 w-px bg-slate-700 mx-1 hidden sm:block"></div>
            <a
              href="https://x.com/fgscaglioni"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-8 h-8 border border-slate-800 bg-[#0a0a0a] hover:border-slate-600 text-slate-600 hover:text-slate-300 transition-all duration-200"
              title="X (Twitter)"
            >
              <i class="fa-brands fa-x-twitter text-xs"></i>
            </a>
            <a
              href="https://www.instagram.com/fgscaglioni"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-8 h-8 border border-slate-800 bg-[#0a0a0a] hover:border-slate-600 text-slate-600 hover:text-slate-300 transition-all duration-200"
              title="Instagram"
            >
              <i class="fa-brands fa-instagram text-xs"></i>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- About + Technical Approach side by side on desktop -->
    <div class="grid lg:grid-cols-2 gap-6 mb-8">
      <section class="brutalist-card p-6 sharp-hover">
        <div
          class="flex items-center gap-3 mb-5 border-b border-slate-800 pb-3"
        >
          <div
            class="w-8 h-8 flex items-center justify-center border border-slate-700"
          >
            <i class="fa-solid fa-user text-slate-400 text-xs"></i>
          </div>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Sobre mim
          </h2>
        </div>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-rose-500/70 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium">+15 anos</strong> atuando em
              todo o ciclo de desenvolvimento — planejamento, arquitetura, frontend
              e backend.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500/70 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium"
                >Doutorando em Ciência da Computação</strong
              > (UFPel), pesquisando <strong class="text-white font-medium"
                >Inteligência Artificial aplicada à Educação</strong
              >.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500/70 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              Experiência em escalar sistemas em produção — de aplicativos
              mobile com <strong class="text-white font-medium"
                >+2k usuários</strong
              > a APIs institucionais integradas com MEC e TCU.
            </span>
          </li>
        </ul>
      </section>

      <section class="brutalist-card p-6 sharp-hover">
        <div
          class="flex items-center gap-3 mb-5 border-b border-slate-800 pb-3"
        >
          <div
            class="w-8 h-8 flex items-center justify-center border border-slate-700"
          >
            <i class="fa-solid fa-code text-slate-400 text-xs"></i>
          </div>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Competências Chave
          </h2>
        </div>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-rose-500/70 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium"
                >Arquitetura de Software</strong
              > — design e implementação de APIs REST, sistemas containerizados com
              Docker e pipelines CI/CD.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500/70 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium"
                >Desenvolvimento Fullstack</strong
              > — Laravel, NestJS, Angular, Ionic e PostgreSQL como stacks principais.
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-rose-500/70 mt-1 text-[10px] shrink-0">■</span>
            <span class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white font-medium">Pesquisa em ML/IA</strong> —
              modelos preditivos educacionais, SLMs e revisões sistemáticas publicadas
              em IEEE.
            </span>
          </li>
        </ul>
      </section>
    </div>

    <!-- Stack Section -->
    <section class="mb-10">
      <div class="flex items-center justify-center gap-3 mb-8">
        <div class="h-px bg-slate-800 flex-grow"></div>
        <h2
          class="text-3xl font-display italic text-white tracking-widest px-4"
        >
          Stack & Tecnologias
        </h2>
        <div class="h-px bg-slate-800 flex-grow"></div>
      </div>
      <StackList />
    </section>

    <!-- Education + Languages -->
    <div class="grid lg:grid-cols-2 gap-6 mb-8">
      <section class="brutalist-card p-6 sharp-hover">
        <div
          class="flex items-center gap-3 mb-6 border-b border-slate-800 pb-3"
        >
          <div
            class="w-8 h-8 flex items-center justify-center border border-slate-700"
          >
            <i class="fa-solid fa-graduation-cap text-slate-400 text-xs"></i>
          </div>
          <h2 class="text-2xl font-display italic text-white tracking-wide">
            Formação Acadêmica
          </h2>
        </div>
        <div class="space-y-4">
          {
            [
              {
                inst: "UFPel",
                href: "https://institucional.ufpel.edu.br/cursos/cod/8102",
                level: "Doutorado em Ciência da Computação",
                period: "2024 - Cursando",
                icon: "fa-circle-dot",
                color: "text-blue-400",
              },
              {
                inst: "UFPel",
                href: "https://institucional.ufpel.edu.br/cursos/cod/7057",
                level: "Mestrado em Ciência da Computação",
                period: "2019 - 2021",
                icon: "fa-circle-dot",
                color: "text-slate-500",
              },
              {
                inst: "UniSenac",
                href: "https://www.senacrs.com.br/unidade/78",
                level: "Especialização em Gerenciamento de Projetos",
                period: "2009 - 2010",
                icon: "fa-square",
                color: "text-slate-600",
              },
              {
                inst: "UniSenac",
                href: "https://www.senacrs.com.br/unidade/78",
                level: "Tecnólogo em Análise e Desenvolvimento de Sistemas",
                period: "2005 - 2007",
                icon: "fa-square",
                color: "text-slate-600",
              },
            ].map((item) => (
              <div class="flex items-start gap-3">
                <div class="mt-1 flex-shrink-0">
                  <i
                    class={`fa-solid ${item.icon} text-[10px] text-rose-500`}
                  />
                </div>
                <div>
                  <a
                    href={item.href}
                    target="_blank"
                    class="text-slate-200 text-sm font-medium hover:text-white transition-colors"
                  >
                    {item.inst}
                  </a>
                  <p class="text-slate-400 font-light text-sm">{item.level}</p>
                  <p class="text-slate-500 text-xs font-mono mt-1 tracking-wider">
                    {item.period}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <div class="space-y-6 flex flex-col">
        <section class="brutalist-card p-6 sharp-hover flex-grow">
          <div
            class="flex items-center gap-3 mb-6 border-b border-slate-800 pb-3"
          >
            <div
              class="w-8 h-8 flex items-center justify-center border border-slate-700"
            >
              <i class="fa-solid fa-globe text-slate-400 text-xs"></i>
            </div>
            <h2 class="text-2xl font-display italic text-white tracking-wide">
              Idiomas
            </h2>
          </div>
          <div class="space-y-3">
            {
              [
                {
                  lang: "Português",
                  level: "Nativo",
                  pct: 100,
                  color: "bg-blue-500",
                },
                {
                  lang: "Inglês",
                  level: "Intermediário",
                  pct: 65,
                  color: "bg-indigo-500",
                },
                {
                  lang: "Espanhol",
                  level: "Básico",
                  pct: 35,
                  color: "bg-purple-500",
                },
                {
                  lang: "Francês",
                  level: "Básico",
                  pct: 25,
                  color: "bg-violet-500",
                },
              ].map((item) => (
                <div>
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-sm text-slate-300 font-medium">
                      {item.lang}
                    </span>
                    <span class="text-xs font-mono text-slate-500 uppercase tracking-widest">
                      {item.level}
                    </span>
                  </div>
                  <div class="w-full bg-[#050505] border border-slate-800 h-2">
                    <div
                      class={`bg-slate-300 h-full`}
                      style={`width: ${item.pct}%`}
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>
