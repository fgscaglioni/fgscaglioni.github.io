---
import "../styles/global.css";
import "@fortawesome/fontawesome-free/css/all.min.css";

interface Props {
  title?: string;
}

const { title = "@fgscaglioni" } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6T5HCKSVKG"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-6T5HCKSVKG");
    </script>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta
      name="description"
      content="Portfólio profissional de Fabrício Scaglioni — desenvolvedor de sistemas, pesquisador e doutorando em IA."
    />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, minimum-scale=1.0"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#050505] text-slate-300 font-sans antialiased min-h-screen">
    <!-- Noise & Base Background -->
    <div class="noise-bg"></div>
    <div class="fixed inset-0 -z-10 pointer-events-none bg-[#050505]"></div>

    <div class="flex min-h-screen max-w-7xl mx-auto">
      <!-- Sidebar -->
      <aside
        class="w-72 flex-shrink-0 hidden lg:flex flex-col sticky top-0 h-screen overflow-y-auto"
      >
        <slot name="sidebar" />
      </aside>

      <!-- Main Content -->
      <main class="flex-grow min-w-0 flex flex-col">
        <slot name="header" />
        <div class="flex-grow px-6 pb-16">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
