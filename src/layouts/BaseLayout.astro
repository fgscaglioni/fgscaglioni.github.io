---
import "../styles/global.css";
import "@fortawesome/fontawesome-free/css/all.min.css";

interface Props {
  title?: string;
}

const { title = "@fgscaglioni" } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6T5HCKSVKG"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-6T5HCKSVKG");
    </script>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta
      name="description"
      content="Portfólio profissional de Fabrício Scaglioni — desenvolvedor de sistemas, pesquisador e doutorando em IA."
    />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, minimum-scale=1.0"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#030303] text-slate-300 font-sans antialiased min-h-screen relative overflow-x-hidden">
    <!-- Header/Navbar slot -->
    <slot name="header" />

    <!-- Main Content Container (Single column layout) -->
    <main class="max-w-3xl mx-auto px-4 sm:px-6 pt-6 pb-20">
      <slot />
    </main>
  </body>
</html>
