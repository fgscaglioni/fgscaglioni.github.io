---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '@fgscaglioni' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-6T5HCKSVKG"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-6T5HCKSVKG');
  </script>
  <meta charset="UTF-8">
  <title>{title}</title>
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
  <meta name="description" content="Description">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0">
</head>
<body class="bg-white text-gray-900 font-sans antialiased flex flex-col min-h-screen">
  
  <div class="flex-grow flex w-full max-w-7xl mx-auto">
    <!-- Sidebar Placeholder -->
    <aside class="w-64 flex-shrink-0 hidden md:block">
      <slot name="sidebar" />
    </aside>

    <!-- Main Content -->
    <main class="flex-grow w-full max-w-4xl px-4 py-8 mx-auto">
       <!-- Header Placeholder -->
      <slot name="header" />
      <slot />
    </main>
  </div>

</body>
</html>
